# Third-party source (cloned by scripts/bootstrap.sh; never committed)
# Note: pattern is third_party/* (not third_party/) so we can re-include
# tracked metadata files like README.md and .gitkeep below.
third_party/*
!third_party/.gitkeep
!third_party/README.md

# Harness state (Claude Code session lock, etc.)
.claude/

# Build artifacts
build/
out/
dist/
*.o
*.obj
*.so
*.so.*
*.dylib
*.dll
*.a
*.lib
*.dSYM/
*.exe

# Test / benchmark outputs (regenerable)
tests/results/
bench/results/
*.bench.json

# Drafts not for publication
docs/_drafts/

# LaTeX intermediate
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.synctex.gz
*.toc
paper/build/

# Editor / OS noise
.DS_Store
.idea/
.vscode/
*.iml
*.swp
*.swo
*~

# clangd local index
.cache/
compile_commands.json

# Python
__pycache__/
*.pyc
.venv/
venv/
.pytest_cache/

# Logs
logs/

# Local-only environment files
.env
.envrc
