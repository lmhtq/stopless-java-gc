 #ifdef __APPLE__
   #include <crt_externs.h>
 #endif
@@ -1190,10 +1197,12 @@
     // and then attached to VM. See notes in os_linux.cpp.
     if (thread->osthread()->expanding_stack() == 0) {
        thread->osthread()->set_expanding_stack();
+#ifdef LINUX
