+  byte_size = MAX2(byte_size, FreeBlocks::MinWordSize * sizeof(MetaWord));
 
   // Metaspace allocations are aligned to word size.
   byte_size = align_up(byte_size, AllocationAlignmentByteSize);
@@ -189,7 +189,7 @@ size_t get_raw_word_size_for_requested_word_size(size_t word_size) {
