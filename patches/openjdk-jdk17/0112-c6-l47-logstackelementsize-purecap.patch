From: lxh <lmhtq1991@gmail.com>
Date: Sat, 30 May 2026 15:45:00 +0800
Subject: [PATCH] Phase C-6 L47: logStackElementSize = 4 on purecap (wordSize != BytesPerWord)

A genuine CHERI bug: on purecap `wordSize = sizeof(char*) = 16` but
`BytesPerWord = 1<<LogBytesPerWord = 8` (the Java word). They are EQUAL
on non-CHERI but DIFFER on CHERI. So:
  stackElementSize    = stackElementWords(1) * wordSize     = 16
  logStackElementSize = LogBytesPerWord                     = 3   (WRONG)
log2(16) = 4, so logStackElementSize must be 4 on purecap. With 3, every
expression-stack index computed by shift uses an ×8 stride over 16-byte
slots — the wrong slot. Fixed to 4 under #ifdef. Also switched
prepare_invoke's hardcoded receiver shift (3) to logStackElementSize.

This advanced the invoke-receiver computation (the null-checked register
changed from 0 to esp[0]) but did not fully resolve it: the actual
receiver oop sits at esp+16 while the formula now reads esp+0, and esp[0]
holds a stray codecache address. That points to an UPSTREAM
operand-stack issue — earlier bytecodes push/pop with a slot stride that
leaves the stack one 16-byte slot off — needing focused tracing (L47b).

NOTE: logStackElementSize is high-leverage and global; it is the correct
value, but the operand-stack push/pop sites must all agree on the 16-byte
slot. The locals-index sites (sub rlocals, idx, LogBytesPerWord) likely
need the same 3->4 correction and will surface next.

Session: 47 commits, 111 build iterations, L25-L46 resolved, L47
(stack-slot log size) corrected, L47b (operand stack) characterized.

Co-Authored-By: Claude Opus 4.8 (1M context) <noreply@anthropic.com>

diff --git a/src/hotspot/cpu/aarch64/templateTable_aarch64.cpp b/src/hotspot/cpu/aarch64/templateTable_aarch64.cpp
index 4666b42b933..d5e9be65a43 100644
--- a/src/hotspot/cpu/aarch64/templateTable_aarch64.cpp
+++ b/src/hotspot/cpu/aarch64/templateTable_aarch64.cpp
@@ -2299,10 +2299,18 @@ void TemplateTable::load_field_cp_cache_entry(Register obj,
 
   // klass overwrite register
   if (is_static) {
+#ifdef __CHERI_PURE_CAPABILITY__
+    // C-6 fix #42: f1 (holder Klass*) and the java_mirror are caps;
+    // integer ldr strips the tag and the following deref faults.
+    __ cap_ldr_imm(obj, cache, in_bytes(cp_base_offset +
+                                        ConstantPoolCacheEntry::f1_offset()));
+    __ cap_ldr_imm(obj, obj, in_bytes(Klass::java_mirror_offset()));
+#else
     __ ldr(obj, Address(cache, in_bytes(cp_base_offset +
                                         ConstantPoolCacheEntry::f1_offset())));
     const int mirror_offset = in_bytes(Klass::java_mirror_offset());
     __ ldr(obj, Address(obj, mirror_offset));
+#endif
     __ resolve_oop_handle(obj);
   }
 }
@@ -2336,9 +2344,17 @@ void TemplateTable::load_invoke_cp_cache_entry(int byte_no,
 
   size_t index_size = (is_invokedynamic ? sizeof(u4) : sizeof(u2));
   resolve_cache_and_index(byte_no, cache, index, index_size);
+#ifdef __CHERI_PURE_CAPABILITY__
+  // C-6 fix #42: the resolved Method* (f1, or f2 for invokevirtual) is a
+  // cap; integer ldr strips the tag and dispatch faults.
+  __ cap_ldr_imm(method, cache, method_offset);
+#else
   __ ldr(method, Address(cache, method_offset));
+#endif
 
   if (itable_index != noreg) {
+    // itable_index comes from f2: a plain integer index (vtable/itable
+    // slot) for the virtual/interface case — an integer load is correct.
     __ ldr(itable_index, Address(cache, index_offset));
   }
   __ ldrw(flags, Address(cache, flags_offset));
@@ -3176,7 +3192,15 @@ void TemplateTable::prepare_invoke(int byte_no,
     // const int receiver_is_at_end      = -1;  // back off one slot to get receiver
     // Address recv_addr = __ argument_address(recv, no_return_pc_pushed_yet + receiver_is_at_end);
     // __ movptr(recv, recv_addr);
+#ifdef __CHERI_PURE_CAPABILITY__
+    // C-6 fix #45/#47: integer add strips esp's cap tag → cap-add. And
+    // the expression-stack slot is stackElementSize (16) bytes on purecap,
+    // so the shift is logStackElementSize (4), not the hardcoded 3.
+    __ lsl(rscratch2, recv, Interpreter::logStackElementSize);
+    __ cap_add_reg(rscratch1, esp, rscratch2);
+#else
     __ add(rscratch1, esp, recv, ext::uxtx, 3); // FIXME: uxtb here?
+#endif
     __ ldr(recv, Address(rscratch1, -Interpreter::expr_offset_in_bytes(1)));
     __ verify_oop(recv);
   }
@@ -3188,8 +3212,18 @@ void TemplateTable::prepare_invoke(int byte_no,
   // load return address
   {
     const address table_addr = (address) Interpreter::invoke_return_entry_table_for(code);
+#ifdef __CHERI_PURE_CAPABILITY__
+    // C-6 fix #46: the return-entry table is a libjvm.so .data global of
+    // 16-byte capability entries. (1) reach it via the data-cap table
+    // (codecache PCC can't address libjvm.so .data); (2) index with ×16
+    // (cap stride), not ×8; (3) cap-LDR the entry so lr is a valid
+    // return capability (the post-call interpreter continuation).
+    __ lea_libjvm_global(rscratch1, table_addr);
+    __ cap_ldr(lr, Address(rscratch1, rscratch2, Address::lsl(4)));
+#else
     __ mov(rscratch1, table_addr);
     __ ldr(lr, Address(rscratch1, rscratch2, Address::lsl(3)));
+#endif
   }
 }
 
diff --git a/src/hotspot/share/interpreter/abstractInterpreter.hpp b/src/hotspot/share/interpreter/abstractInterpreter.hpp
index 2fb5b97e808..5dbdeeb8853 100644
--- a/src/hotspot/share/interpreter/abstractInterpreter.hpp
+++ b/src/hotspot/share/interpreter/abstractInterpreter.hpp
@@ -223,7 +223,16 @@ class AbstractInterpreter: AllStatic {
   // Interpreter helpers
   const static int stackElementWords   = 1;
   const static int stackElementSize    = stackElementWords * wordSize;
+#ifdef __CHERI_PURE_CAPABILITY__
+  // C-6 fix #47: on purecap wordSize = sizeof(char*) = 16, so
+  // stackElementSize = 16 and the shift must be log2(16) = 4. The stock
+  // definition `= LogBytesPerWord` (3) is the JAVA-word log, which on
+  // CHERI differs from the machine word (8 vs 16) and would index the
+  // 16-byte expression-stack slots with an ×8 stride (wrong slot).
+  const static int logStackElementSize = 4;
+#else
   const static int logStackElementSize = LogBytesPerWord;
+#endif
 
   static int expr_index_at(int i) {
     return stackElementWords * i;
