       sve_str(as_FloatRegister(i), Address(sp, i));
     }
   } else {
-    int step = (save_vectors ? 8 : 4) * wordSize;
+    int step = (save_vectors ? 8 : 4) * BytesPerLong;  // CHERI: SIMD stride not pointer
     mov(rscratch1, -step);
     sub(sp, sp, step);
     for (int i = 28; i >= 4; i -= 4) {
@@ -2829,7 +2865,7 @@ void MacroAssembler::pop_CPU_state(bool restore_vectors, bool use_sve,
     }
     add(sp, sp, sve_vector_size_in_bytes * FloatRegisterImpl::number_of_registers);
   } else {
-    int step = (restore_vectors ? 8 : 4) * wordSize;
+    int step = (restore_vectors ? 8 : 4) * BytesPerLong;  // CHERI: SIMD stride not pointer
     for (int i = 0; i <= 28; i += 4)
       ld1(as_FloatRegister(i), as_FloatRegister(i+1), as_FloatRegister(i+2),
           as_FloatRegister(i+3), restore_vectors ? T2D : T1D, Address(post(sp, step)));
@@ -3942,10 +3978,18 @@ void MacroAssembler::resolve_weak_handle(Register rresult, Register rtmp) {
 
 void MacroAssembler::load_mirror(Register dst, Register method, Register tmp) {
   const int mirror_offset = in_bytes(Klass::java_mirror_offset());
+#ifdef __CHERI_PURE_CAPABILITY__
+  // C-6 fix #22: chained pointer loads need cap-LDR to preserve tags.
+  cap_ldr_imm(dst, rmethod, in_bytes(Method::const_offset()));
+  cap_ldr_imm(dst, dst, in_bytes(ConstMethod::constants_offset()));
+  cap_ldr_imm(dst, dst, ConstantPool::pool_holder_offset_in_bytes());
+  cap_ldr_imm(dst, dst, mirror_offset);
+#else
   ldr(dst, Address(rmethod, Method::const_offset()));
   ldr(dst, Address(dst, ConstMethod::constants_offset()));
   ldr(dst, Address(dst, ConstantPool::pool_holder_offset_in_bytes()));
   ldr(dst, Address(dst, mirror_offset));
+#endif
   resolve_oop_handle(dst, tmp);
 }
 
diff --git a/src/hotspot/cpu/aarch64/macroAssembler_aarch64.hpp b/src/hotspot/cpu/aarch64/macroAssembler_aarch64.hpp
index 9b1c0a93539..b98d9a252b3 100644
--- a/src/hotspot/cpu/aarch64/macroAssembler_aarch64.hpp
+++ b/src/hotspot/cpu/aarch64/macroAssembler_aarch64.hpp
@@ -237,9 +237,43 @@ class MacroAssembler: public Assembler {
     assert(Rd != r31_sp && Rn != r31_sp, "should be");
     if (Rd == Rn) {
     } else if (Rd == sp || Rn == sp) {
+#ifdef __CHERI_PURE_CAPABILITY__
+      // C-6 fix #13: mov(Reg, sp) / mov(sp, Reg) — Assembler::add emits
+      // INTEGER ADD (0x91xxxxxx) which doesn't preserve cap tag. Emit
+      // Morello cap-ADD (0x02000000-family) directly. sp/csp encodes as
+      // register #31 in instructions.
+      unsigned rd_enc = (Rd == sp) ? 31u : (unsigned)Rd->encoding();
+      unsigned rn_enc = (Rn == sp) ? 31u : (unsigned)Rn->encoding();
+      emit_int32(0x02000000U | (rn_enc << 5) | rd_enc);
+#else
       Assembler::add(Rd, Rn, 0U);
+#endif
+    } else if (Rd == zr || Rn == zr) {
+      // Either Rd is zr (write discarded, no-op) or Rn is zr (writing
+      // integer zero to Rd; the cap-tag-clearing is intended). Use
+      // the classic orr, which knows how to encode HotSpot's pseudo
+      // zr (#32) as the AArch64 ZR (#31) in the ORR instruction
+      // family. Cap-preserving move is not needed here.
+      orr(Rd, zr, Rn);
     } else {
+#ifdef __CHERI_PURE_CAPABILITY__
+      // C-6 fix #8: emit the Morello MOV (Capability) instruction
+      // directly. Encoding: 0xC2C1D000 | (Rn << 5) | Rd, where Rd
+      // and Rn are 5-bit (0..30). Confirmed via Morello clang:
+      //   mov c0, c1  -> 0xC2C1D020
+      //   mov c19, c0 -> 0xC2C1D013
+      //   mov c2, c3  -> 0xC2C1D062
+      // Prior attempts (orr Rd, ZR, Rn — integer; add Rd, Rn, #0 —
+      // also integer ADD imm at opcode 0x91xxxxxx, NOT the cap-ADD
+      // at 0x02xxxxxx) both clear the cap tag. The MOV (Capability)
+      // instruction at 0xC2C1Dxxx is the canonical preserving form.
+      // Concrete symptom: forward_exception's `__ mov(r19, r0)`
+      // had been losing the tag of the exception handler address,
+      // so `__ br(r19)` SIGPROT'd at the tag-zero PC.
+      emit_int32(0xC2C1D000 | (Rn->encoding() << 5) | Rd->encoding());
+#else
       orr(Rd, zr, Rn);
+#endif
     }
   }
 
@@ -510,6 +544,14 @@ public:
   inline void mov(Register dst, unsigned int imm64)       { mov_immediate64(dst, (uint64_t)imm64); }
   inline void mov(Register dst, unsigned long imm64)      { mov_immediate64(dst, (uint64_t)imm64); }
   inline void mov(Register dst, unsigned long long imm64) { mov_immediate64(dst, (uint64_t)imm64); }
+#ifdef __CHERI_PURE_CAPABILITY__
+  // On CHERI/Morello purecap, intptr_t is __intcap (a capability), which
+  // does not match any of the integer overloads above. Provide a dedicated
+  // overload so call sites like mov(dst, src.as_constant()) where
+  // as_constant() returns intptr_t do not suffer ambiguous-overload errors.
+  inline void mov(Register dst, intptr_t imm64)            { mov_immediate64(dst, (uint64_t)(uintptr_t)imm64); }
+  inline void mov(Register dst, uintptr_t imm64)           { mov_immediate64(dst, (uint64_t)imm64); }
+#endif
 
   inline void movw(Register dst, uint32_t imm32)
   {
@@ -699,16 +741,111 @@ public:
   // Alignment
   void align(int modulus);
 
+#ifdef __CHERI_PURE_CAPABILITY__
+  // C-6 fix #12 helpers: emit Morello cap-STR and cap-STP directly.
+  // HotSpot's Assembler::str/stp emit integer encodings (0xf9xxxxxx /
+  // 0xa9xxxxxx) that are either illegal in C64 mode or silently drop
+  // cap tags. Cap variants: 0xC2 (STR), 0xA2 (STUR), 0x42 (STP).
+  // Verified vs Morello clang (see docs/27 + docs/28).
+  // Use these explicitly in stubs where the register holds a cap.
+
+  // str Ct, [Cn, #imm]   (cap, 16-byte, signed-offset)
+  inline void cap_str_imm(Register Ct, Register Cn, int imm) {
+    if (imm >= 0 && (imm % 16) == 0 && imm < 16 * 4096) {
+      // STR (immediate, unsigned offset): imm12 scaled by 16.
+      emit_int32(0xC2000000U | (((unsigned)imm / 16) << 10)
+                 | (Cn->encoding() << 5) | Ct->encoding());
+    } else {
+      // STUR (immediate, signed 9-bit unscaled).
+      emit_int32(0xA2000000U | (((unsigned)imm & 0x1FF) << 12)
+                 | (Cn->encoding() << 5) | Ct->encoding());
+    }
+  }
+  // stp Ct, Ct2, [Cn, #imm]   (cap-pair, 32 bytes total, signed-offset)
+  inline void cap_stp_imm(Register Ct, Register Ct2, Register Cn, int imm) {
+    // imm7 = imm/16 (signed 7-bit), scaled by 16.
+    emit_int32(0x42800000U | ((((unsigned)imm / 16) & 0x7F) << 15)
+               | (Ct2->encoding() << 10) | (Cn->encoding() << 5)
+               | Ct->encoding());
+  }
+  // ldr Ct, [Cn, #imm]   (cap, 16-byte, signed-offset)
+  inline void cap_ldr_imm(Register Ct, Register Cn, int imm) {
+    if (imm >= 0 && (imm % 16) == 0 && imm < 16 * 4096) {
+      emit_int32(0xC2400000U | (((unsigned)imm / 16) << 10)
+                 | (Cn->encoding() << 5) | Ct->encoding());
+    } else {
+      emit_int32(0xA2400000U | (((unsigned)imm & 0x1FF) << 12)
+                 | (Cn->encoding() << 5) | Ct->encoding());
+    }
+  }
+  // ldp Ct, Ct2, [Cn, #imm]   (cap-pair, 32 bytes total, signed-offset)
+  inline void cap_ldp_imm(Register Ct, Register Ct2, Register Cn, int imm) {
+    emit_int32(0x42C00000U | ((((unsigned)imm / 16) & 0x7F) << 15)
+               | (Ct2->encoding() << 10) | (Cn->encoding() << 5)
+               | Ct->encoding());
+  }
+  // sub Cd, Cn, #imm12   (cap-sub immediate)
+  inline void cap_sub_imm(Register Cd, Register Cn, unsigned imm12) {
+    unsigned rd_enc = (Cd == sp) ? 31u : (unsigned)Cd->encoding();
+    unsigned rn_enc = (Cn == sp) ? 31u : (unsigned)Cn->encoding();
+    emit_int32(0x02800000U | ((imm12 & 0xFFF) << 10) | (rn_enc << 5) | rd_enc);
+  }
+  // blr Cn   (Morello "Branch with Link to Capability"). UNLIKE the
+  // integer `blr Xn` (0xd63f0000-family) which only updates PC within
+  // the CURRENT PCC bounds, this installs Cn as the NEW PCC. Required
+  // for any call whose target lies OUTSIDE the caller's PCC bounds —
+  // e.g. a codecache stub calling into libjvm.so .text. Verified vs
+  // Morello clang: `blr c0` = 0xC2C23000, so `blr cN` = 0xC2C23000 |
+  // (Rn<<5). (Cf. `ret c30` = 0xC2C253C0 = 0xC2C25000 | (30<<5).)
+  inline void cap_blr(Register Cn) {
+    emit_int32(0xC2C23000U | ((unsigned)Cn->encoding() << 5));
+  }
+  // br Cn    (Morello cap branch, no link). `br c0` = 0xC2C21000.
+  inline void cap_br(Register Cn) {
+    emit_int32(0xC2C21000U | ((unsigned)Cn->encoding() << 5));
+  }
+#endif
+
   // Stack frame creation/removal
   void enter()
   {
+#ifdef __CHERI_PURE_CAPABILITY__
+    // C-6 fix #9: emit Morello cap-stp + cap-mov in stack frame setup.
+    // The standard AArch64 STP (0xA9...) emitted by stp(Reg,Reg,Address)
+    // is INTEGER stp — it stores 8-byte pairs and clears the cap tag
+    // of rfp/lr in the destination memory. The Morello cap-STP
+    // (0x62800000-family) stores 16-byte cap pairs preserving tags.
+    // Encoding (cap-stp pre-imm): 0x62800000 | ((imm7) << 15)
+    //                              | (Rt2<<10) | (Rn<<5) | Rt
+    // where imm7 = byte_offset / 16 (signed 7-bit).
+    // For -2*wordSize = -32 bytes, imm7 = -2 = 0x7E (7-bit signed).
+    //   0x62800000 | (0x7E << 15) | (30<<10) | (31<<5) | 29 = 0x62BF7BFD
+    // Note: SP/CSP encodes as register #31 in instructions (not the
+    // pseudo #33 used as HotSpot's `sp` Register*).
+    emit_int32(0x62800000 | ((-32/16 & 0x7F) << 15) |
+               (30 << 10) | (31 << 5) | 29);
+    // mov(rfp, sp) — emit cap-add #0 from csp.
+    //   0x02000000 | (0<<22) | (0<<10) | (31<<5) | 29 = 0x020003FD
+    emit_int32(0x02000000 | (31 << 5) | 29);
+#else
     stp(rfp, lr, Address(pre(sp, -2 * wordSize)));
     mov(rfp, sp);
+#endif
   }
   void leave()
   {
+#ifdef __CHERI_PURE_CAPABILITY__
+    // mirror of enter(): cap-add sp,rfp,#0 then cap-ldp post-imm +32
+    //   0x02000000 | (29 << 5) | 31 = 0x020003BF (sp <- rfp + 0)
+    emit_int32(0x02000000 | (29 << 5) | 31);
+    // cap-ldp post-imm: 0x22C00000 | ((imm7) << 15) | (Rt2<<10) | (Rn<<5) | Rt
+    //   0x22C00000 | (2 << 15) | (30<<10) | (31<<5) | 29 = 0x22C17BFD
+    emit_int32(0x22C00000 | ((32/16 & 0x7F) << 15) |
+               (30 << 10) | (31 << 5) | 29);
+#else
     mov(sp, rfp);
     ldp(rfp, lr, Address(post(sp, 2 * wordSize)));
+#endif
   }
 
