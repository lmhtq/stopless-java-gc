From: lxh <lmhtq1991@gmail.com>
Date: Wed, 27 May 2026 19:00:00 +0800
Subject: [PATCH] Phase C-3a: link cap_runtime/libstopless_gc.a into libjvm.so

When the build is configured with `--with-jvm-features=stoplessgc`,
add the static library `cap_runtime/stopless_gc/libstopless_gc.a` to
libjvm.so's link line, and add the corresponding include path for the
C API headers.

`-lcheri_caprevoke` is the CheriBSD-provided revocation helper that
our C runtime already links against; libjvm.so inherits this need.

Design: docs/c3/design.md

diff --git a/make/hotspot/lib/JvmFeatures.gmk b/make/hotspot/lib/JvmFeatures.gmk
--- a/make/hotspot/lib/JvmFeatures.gmk
+++ b/make/hotspot/lib/JvmFeatures.gmk
@@ -130,8 +130,18 @@ endif
 ifneq ($(call check-jvm-feature, stoplessgc), true)
   JVM_CFLAGS_FEATURES += -DINCLUDE_STOPLESSGC=0
   JVM_EXCLUDE_PATTERNS += gc/stopless
 else
   JVM_CFLAGS_FEATURES += -DINCLUDE_STOPLESSGC=1
+  # Path layout assumed:
+  #   $(TOPDIR)/../cap_runtime/stopless_gc/  (libstopless_gc.a + *.h)
+  STOPLESS_RUNTIME_DIR ?= $(TOPDIR)/../cap_runtime/stopless_gc
+  ifneq ($(wildcard $(STOPLESS_RUNTIME_DIR)/libstopless_gc.a),)
+    JVM_LIBS_FEATURES += $(STOPLESS_RUNTIME_DIR)/libstopless_gc.a -lcheri_caprevoke
+    JVM_CFLAGS_FEATURES += -I$(STOPLESS_RUNTIME_DIR)
+  else
+    $(warning STOPLESSGC enabled but $(STOPLESS_RUNTIME_DIR)/libstopless_gc.a not built)
+    $(warning Run: make -C $(STOPLESS_RUNTIME_DIR) CROSS=1)
+  endif
 endif
