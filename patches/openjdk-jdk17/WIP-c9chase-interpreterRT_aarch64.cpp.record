diff --git a/src/hotspot/cpu/aarch64/interpreterRT_aarch64.cpp b/src/hotspot/cpu/aarch64/interpreterRT_aarch64.cpp
index f5970adc412..c2c6d5fdc6c 100644
--- a/src/hotspot/cpu/aarch64/interpreterRT_aarch64.cpp
+++ b/src/hotspot/cpu/aarch64/interpreterRT_aarch64.cpp
@@ -39,6 +39,17 @@
 
 #define __ _masm->
 
+#ifdef __CHERI_PURE_CAPABILITY__
+// C-9: compute dst = src + off as a TAGGED capability (src is rlocals). The
+// stock integer `add` strips the tag, so the jobject arg address handed to the
+// native function (or dereferenced by the handler) faults. local_offset can be
+// negative, so pick cap-add / cap-sub by sign.
+static inline void cap_lea_off(MacroAssembler* _masm, Register dst, Register src, int off) {
+  if (off >= 0) __ cap_add_imm(dst, src, (unsigned)off);
+  else          __ cap_sub_imm(dst, src, (unsigned)(-off));
+}
+#endif
+
 // Implementation of SignatureHandlerGenerator
 Register InterpreterRuntime::SignatureHandlerGenerator::from() { return rlocals; }
 Register InterpreterRuntime::SignatureHandlerGenerator::to()   { return sp; }
@@ -63,10 +74,25 @@ FloatRegister InterpreterRuntime::SignatureHandlerGenerator::next_fpr() {
 // for example double/long should be 8 bytes aligned.
 
 int InterpreterRuntime::SignatureHandlerGenerator::next_stack_offset(unsigned elem_size) {
+#ifdef __CHERI_PURE_CAPABILITY__
+  // purecap AAPCS: each stack argument occupies max(8, sizeof(arg)) bytes,
+  // aligned to its natural alignment (16 for capabilities). Advancing a
+  // uniform wordSize (16) per argument misplaces every argument after the
+  // first stack-passed int — defineClass0's (pd, initialize, flags,
+  // classData) stack tail then delivered a garbage non-NULL classData
+  // ("classData is only applicable for hidden classes" InternalError in the
+  // indy bootstrap's hidden-class definition).
+  unsigned slot = elem_size < 8 ? 8 : elem_size;
+  _stack_offset = align_up(_stack_offset, (int)slot);
+  int ret = _stack_offset;
+  _stack_offset += slot;
+  return ret;
+#else
   MACOS_ONLY(_stack_offset = align_up(_stack_offset, elem_size));
   int ret = _stack_offset;
   _stack_offset += NOT_MACOS(wordSize) MACOS_ONLY(elem_size);
   return ret;
+#endif
 }
 
 InterpreterRuntime::SignatureHandlerGenerator::SignatureHandlerGenerator(
@@ -153,9 +179,17 @@ void InterpreterRuntime::SignatureHandlerGenerator::pass_object() {
   Register reg = next_gpr();
   if (reg == c_rarg1) {
     assert(offset() == 0, "argument register 1 can only be (non-null) receiver");
+#ifdef __CHERI_PURE_CAPABILITY__
+    cap_lea_off(_masm, c_rarg1, from(), Interpreter::local_offset_in_bytes(offset()));
+#else
     __ add(c_rarg1, from(), Interpreter::local_offset_in_bytes(offset()));
+#endif
   } else if (reg != noreg) {
+#ifdef __CHERI_PURE_CAPABILITY__
+    cap_lea_off(_masm, r0, from(), Interpreter::local_offset_in_bytes(offset()));
+#else
     __ add(r0, from(), Interpreter::local_offset_in_bytes(offset()));
+#endif
     __ mov(reg, 0);
     __ ldr(temp(), r0);
     Label L;
@@ -163,6 +197,24 @@ void InterpreterRuntime::SignatureHandlerGenerator::pass_object() {
     __ mov(reg, r0);
     __ bind(L);
   } else {
+    // Stack-passed oop arg (>8 GPR args), e.g. defineClass1's 9th arg
+    // `source` — hit for every user-class definition from a jar/file URL.
+#ifdef __CHERI_PURE_CAPABILITY__
+    // The handle is a capability: an integer str keeps only its low 8 bytes
+    // and drops the tag, so the callee's JNIHandles::resolve SIGPROTs.
+    // cap_str_imm can't take to()==sp as base; temp() is free after the
+    // null check, so copy csp into it (cap_add_imm special-cases sp) and
+    // cap-STR the full 16-byte handle through that.
+    cap_lea_off(_masm, r0, from(), Interpreter::local_offset_in_bytes(offset()));
+    __ ldr(temp(), r0);
+    Label L;
+    __ cbnz(temp(), L);
+    __ mov(r0, zr);
+    __ bind(L);
+    static_assert(sizeof(jobject) == wordSize, "");
+    __ cap_add_imm(temp(), to(), 0);
+    __ cap_str_imm(r0, temp(), next_stack_offset(sizeof(jobject)));
+#else
     __ add(r0, from(), Interpreter::local_offset_in_bytes(offset()));
     __ ldr(temp(), r0);
     Label L;
@@ -171,6 +223,7 @@ void InterpreterRuntime::SignatureHandlerGenerator::pass_object() {
     __ bind(L);
     static_assert(sizeof(jobject) == wordSize, "");
     __ str(r0, Address(to(), next_stack_offset(sizeof(jobject))));
+#endif
   }
 }
 
@@ -180,7 +233,16 @@ void InterpreterRuntime::SignatureHandlerGenerator::generate(uint64_t fingerprin
 
   // return result handler
   __ lea(r0, ExternalAddress(Interpreter::result_handler(method()->result_type())));
+#ifdef __CHERI_PURE_CAPABILITY__
+  // C-9 §AF: this generated signature handler is cap-BLR'd from the native entry,
+  // so lr is a sealed return sentry. The stock integer `ret lr` lands on an odd PC
+  // (C64 bit0) -> SIGBUS, and clearing bit0 + integer ret keeps the HANDLER's PCC
+  // (wrong bounds). Use a cap-RET (`ret c30`=0xc2c253c0): it unseals the sentry,
+  // restoring the native-entry PCC bounds and PSTATE.C64 mode.
+  __ emit_int32(0xC2C25000U | (30U << 5));   // ret c30 (cap-RET)
+#else
   __ ret(lr);
+#endif
 
   __ flush();
 }
