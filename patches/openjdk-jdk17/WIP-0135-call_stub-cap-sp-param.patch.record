@@ -5700,9 +5799,22 @@ class StubGenerator: public StubCodeGenerator {
   }
 
   void generate_string_indexof_stubs() {
+#ifdef __CHERI_PURE_CAPABILITY__
+    // C-6: skip string-indexof stub generation on CHERI purecap.
+    // generate_string_indexof_linear emits a sub immediate that
+    // doesn't fit the 12-bit add/sub field, so wrap_adds_subs_imm_insn
+    // falls back to mov(Rd, imm)+sub-reg, and the mov path trips the
+    // assembler imms-field guarantee (val=64 in a 6-bit field).
+    // Leaving these as nullptr makes the JIT fall back to the Java
+    // String.indexOf implementation — correct but unoptimized.
+    StubRoutines::aarch64::_string_indexof_linear_ll = nullptr;
+    StubRoutines::aarch64::_string_indexof_linear_uu = nullptr;
+    StubRoutines::aarch64::_string_indexof_linear_ul = nullptr;
+#else
     StubRoutines::aarch64::_string_indexof_linear_ll = generate_string_indexof_linear(true, true);
     StubRoutines::aarch64::_string_indexof_linear_uu = generate_string_indexof_linear(false, false);
     StubRoutines::aarch64::_string_indexof_linear_ul = generate_string_indexof_linear(true, false);
+#endif
   }
 
   void inflate_and_store_2_fp_registers(bool generatePrfm,
