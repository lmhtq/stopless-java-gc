@@ -227,11 +227,38 @@ class StubGenerator: public StubCodeGenerator {
 
     // set up frame and move sp to end of save area
     __ enter();
+#ifdef __CHERI_PURE_CAPABILITY__
+    // C-6 fix #11: __ sub(sp, rfp, imm) defaults to integer SUB encoding
+    // (0xd1xxxxxx) which is ILLEGAL in C64 mode. Emit Morello cap-SUB
+    // (0x028xxxxx) directly. Pattern: 0x02800000 | (sh<<22) | (imm12<<10)
+    // | (Rn<<5) | Rd. For imm = -sp_after_call_off * wordSize = 26 * 16 = 0x1A0,
+    // Rd=31 (csp), Rn=29 (rfp): 0x02800000 | (0x1A0<<10) | (29<<5) | 31
+    // = 0x028683BF (verified vs clang).
+    {
+      unsigned imm12 = (unsigned)(-sp_after_call_off * wordSize) & 0xFFF;
+      __ emit_int32(0x02800000 | (imm12 << 10) | (29 << 5) | 31);
+    }
+#else
     __ sub(sp, rfp, -sp_after_call_off * wordSize);
+#endif
 
     // save register parameters and Java scratch/global registers
     // n.b. we save thread even though it gets installed in
     // rthread because we want to sanity check rthread later
+#ifdef __CHERI_PURE_CAPABILITY__
+    // C-6 fix #12: Assembler::str/stp emit integer-only encodings.
+    // For cap-typed values we must emit Morello cap-STR/cap-STP.
+    __ cap_str_imm(c_rarg7, rfp, thread_off         * wordSize);
+    __ strw       (c_rarg6, parameter_size);  // 32-bit data; integer OK
+    __ cap_stp_imm(c_rarg4, c_rarg5, rfp, entry_point_off  * wordSize);
+    __ cap_stp_imm(c_rarg2, c_rarg3, rfp, result_type_off  * wordSize);
+    __ cap_stp_imm(c_rarg0, c_rarg1, rfp, call_wrapper_off * wordSize);
+    __ cap_stp_imm(r20, r19, rfp, r20_off * wordSize);
+    __ cap_stp_imm(r22, r21, rfp, r22_off * wordSize);
+    __ cap_stp_imm(r24, r23, rfp, r24_off * wordSize);
+    __ cap_stp_imm(r26, r25, rfp, r26_off * wordSize);
+    __ cap_stp_imm(r28, r27, rfp, r28_off * wordSize);
+#else
     __ str(c_rarg7,  thread);
     __ strw(c_rarg6, parameter_size);
     __ stp(c_rarg4, c_rarg5,  entry_point);
@@ -243,12 +270,14 @@ class StubGenerator: public StubCodeGenerator {
     __ stp(r24, r23,   r24_save);
     __ stp(r26, r25,   r26_save);
     __ stp(r28, r27,   r28_save);
+#endif
 
     __ stpd(v9,  v8,   d9_save);
     __ stpd(v11, v10,  d11_save);
     __ stpd(v13, v12,  d13_save);
     __ stpd(v15, v14,  d15_save);
 
+
     // install Java thread in global register now we have saved
     // whatever value it held
     __ mov(rthread, c_rarg7);
@@ -271,8 +300,26 @@ class StubGenerator: public StubCodeGenerator {
 #endif
     // pass parameters if any
     __ mov(esp, sp);
+#ifdef __CHERI_PURE_CAPABILITY__
+    // C-9 fix (§S-class): the stock `sub(rscratch1,sp,..)` + `andr(sp,..)` strip
+    // CSP's capability tag (integer ops writing sp). For a no-param call (e.g. a
+    // static <clinit>) the push loop is skipped, so the only effect is that
+    // `mov(r13,sp)` below stores an UNTAGGED sender_sp into the entry frame; a
+    // later cap-LDR of that slot (remove_activation) then yields a tag-0 CSP.
+    // Compute the (32-aligned) parameter-area delta and cap-SUB it from CSP,
+    // preserving the tag. CSP is 32-aligned here (enter + the cap-sub above), so
+    // aligning the delta keeps CSP aligned.
+    __ lslw(rscratch1, c_rarg6, LogBytesPerWord);      // params * 8
+    __ add(rscratch1, rscratch1, 2 * wordSize - 1);
+    __ andr(rscratch1, rscratch1, -2 * wordSize);      // round up the DELTA
+    __ neg(rscratch1, rscratch1);                      // -delta
+    // add csp, csp, rscratch1, uxtx  (cap-add reg, preserves CSP tag; csp=#31)
+    __ emit_int32(0xC2A06000U | ((unsigned)rscratch1->encoding() << 16)
+                  | (31U << 5) | 31U);
+#else
     __ sub(rscratch1, sp, c_rarg6, ext::uxtw, LogBytesPerWord); // Move SP out of the way
     __ andr(sp, rscratch1, -2 * wordSize);
+#endif
 
     BLOCK_COMMENT("pass parameters if any");
     Label parameters_done;
@@ -293,6 +340,11 @@ class StubGenerator: public StubCodeGenerator {
     //      r13: sender sp
     BLOCK_COMMENT("call Java function");
     __ mov(r13, sp);
+    // C-6 fix #17 (replaces #16): bit-0 mode bit on c_rarg4 is now set
+    // by C++ side (javaCalls.cpp) using cheri_address_set, NOT here via
+    // cap-ADD. Stub-emit cap-ADD #1 produced a cap whose BLR resulted in
+    // ifetch from misaligned PC (SIGBUS alignment), while cheri_address_set
+    // works correctly. Probably cheri_address_set also updates cap flags.
     __ blr(c_rarg4);
 
     // we do this here because the notify will already have been done
@@ -330,7 +382,11 @@ class StubGenerator: public StubCodeGenerator {
     __ BIND(exit);
 
     // pop parameters
+#ifdef __CHERI_PURE_CAPABILITY__
+    __ cap_sub_imm(esp, rfp, (unsigned)(-sp_after_call_off * wordSize));
+#else
     __ sub(esp, rfp, -sp_after_call_off * wordSize);
+#endif
 
 #ifdef ASSERT
     // verify that threads correspond
@@ -354,6 +410,21 @@ class StubGenerator: public StubCodeGenerator {
     __ ldpd(v11, v10,  d11_save);
     __ ldpd(v9,  v8,   d9_save);
 
+#ifdef __CHERI_PURE_CAPABILITY__
+    // C-6 fix #14: cap-LDP for callee-saved register restore (mirror
+    // of cap-STP fix in prologue).
+    __ cap_ldp_imm(r28, r27, rfp, r28_off * wordSize);
+    __ cap_ldp_imm(r26, r25, rfp, r26_off * wordSize);
+    __ cap_ldp_imm(r24, r23, rfp, r24_off * wordSize);
+    __ cap_ldp_imm(r22, r21, rfp, r22_off * wordSize);
+    __ cap_ldp_imm(r20, r19, rfp, r20_off * wordSize);
+
+    __ cap_ldp_imm(c_rarg0, c_rarg1, rfp, call_wrapper_off * wordSize);
+    __ ldrw(c_rarg2, result_type);   // 32-bit int load OK
+    __ cap_ldr_imm(c_rarg3, rfp, method_off * wordSize);
+    __ cap_ldp_imm(c_rarg4, c_rarg5, rfp, entry_point_off * wordSize);
+    __ cap_ldp_imm(c_rarg6, c_rarg7, rfp, parameter_size_off * wordSize);
+#else
     __ ldp(r28, r27,   r28_save);
     __ ldp(r26, r25,   r26_save);
     __ ldp(r24, r23,   r24_save);
@@ -365,6 +436,7 @@ class StubGenerator: public StubCodeGenerator {
     __ ldr(c_rarg3,  method);
     __ ldp(c_rarg4, c_rarg5,  entry_point);
     __ ldp(c_rarg6, c_rarg7,  parameter_size);
+#endif
 
     // leave frame and return to caller
     __ leave();
@@ -384,6 +456,33 @@ class StubGenerator: public StubCodeGenerator {
     __ strd(j_farg0, Address(j_rarg2, 0));
     __ br(Assembler::AL, exit);
 
+#ifdef __CHERI_PURE_CAPABILITY__
+    {
+      // C-6 diag: scan full call_stub buffer for integer-encoded
+      // instructions that need cap variants.
+      uint32_t* p = (uint32_t*)aarch64_entry;
+      uint32_t* end = (uint32_t*)__ pc();
+      int total = (int)(end - p);
+      fprintf(stderr, "[C6CSSCAN] call_stub 0x%p..0x%p (%d insns), suspect integer encodings:\n",
+              aarch64_entry, end, total);
+      int suspect_count = 0;
+      for (int i = 0; i < total; i++) {
+        uint32_t insn = p[i];
+        unsigned top = insn >> 24;
+        bool susp = (top == 0xa9 || top == 0xa8 || top == 0xa7 || top == 0xa6 ||
+                     top == 0xf9 || top == 0xf8 ||
+                     top == 0xd1 || top == 0x91 || top == 0x51 || top == 0xd0 ||
+                     top == 0xaa);
+        if (susp && suspect_count < 20) {
+          fprintf(stderr, "  +%03d: 0x%08x (top=0x%02x)\n", i*4, insn, top);
+          suspect_count++;
+        }
+      }
+      fprintf(stderr, "[C6CSSCAN] total suspect=%d\n", suspect_count);
+      fflush(stderr);
+    }
+#endif
+
     return start;
   }
 
@@ -4910,7 +5009,7 @@ class StubGenerator: public StubCodeGenerator {
