--- a/src/hotspot/share/runtime/thread.hpp
+++ b/src/hotspot/share/runtime/thread.hpp
@@ -555,6 +555,15 @@ protected:
   size_t           _stack_size;
   int              _lgrp_id;
 
+#ifdef __CHERI_PURE_CAPABILITY__
+  // C-6 fix #25 (Option C): valid cap to cap_trampoline_dispatch, used by
+  // stub-emitted call_VM_leaf_base to BLR into libjvm.so .text whose
+  // address range is OUTSIDE codecache PCC bounds. Loaded once at Thread
+  // construction from C++ space (where the function pointer has wide
+  // bounds via the linker).
+  void*            _cap_trampoline_addr;
+#endif
+
  public:
   // Stack overflow support
   address stack_base() const           { assert(_stack_base != NULL,"Sanity check"); return _stack_base; }
@@ -612,6 +621,9 @@ protected:
 
   static ByteSize stack_base_offset()            { return byte_offset_of(Thread, _stack_base); }
   static ByteSize stack_size_offset()            { return byte_offset_of(Thread, _stack_size); }
+#ifdef __CHERI_PURE_CAPABILITY__
+  static ByteSize cap_trampoline_addr_offset()   { return byte_offset_of(Thread, _cap_trampoline_addr); }
+#endif
 
   static ByteSize tlab_start_offset()            { return byte_offset_of(Thread, _tlab) + ThreadLocalAllocBuffer::start_offset(); }
   static ByteSize tlab_end_offset()              { return byte_offset_of(Thread, _tlab) + ThreadLocalAllocBuffer::end_offset(); }
