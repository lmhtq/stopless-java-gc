+#define GC_STOPLESS_FLAGS(develop,                                       \
+                          develop_pd,                                    \
+                          product,                                       \
+                          product_pd,                                    \
+                          notproduct,                                    \
+                          range,                                         \
+                          constraint)                                    \
+                                                                          \
+  product(size_t, StoplessArenaSize, 256 * M,                            \
+          "Size of each Stopless arena in bytes")                        \
+          range(4 * M, max_uintx)                                        \
+                                                                          \
+  product(uintx, StoplessGCCount, 0, DIAGNOSTIC,                         \
+          "(Diagnostic) Number of Stopless concurrent cycles performed")
+
+#endif // SHARE_GC_STOPLESS_STOPLESS_GLOBALS_HPP
