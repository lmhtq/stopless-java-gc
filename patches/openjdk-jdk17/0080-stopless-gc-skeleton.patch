+/*
+ * Copyright (c) 2026, bluecat. CHERI-Stopless GC for OpenJDK.
+ *
+ * Phase C-1 skeleton — see docs/c1/design.md.
+ */
+
+#include "precompiled.hpp"
+#include "gc/stopless/stoplessArguments.hpp"
+#include "gc/stopless/stoplessHeap.hpp"
+#include "gc/shared/gcArguments.hpp"
+#include "runtime/globals.hpp"
+#include "runtime/globals_extension.hpp"
+
+void StoplessArguments::initialize_alignments() {
+  size_t page_size = UseLargePages ? os::large_page_size() : os::vm_page_size();
+  size_t align = MAX2((size_t)os::vm_allocation_granularity(), page_size);
+  SpaceAlignment = align;
+  HeapAlignment  = align;
+}
+
+void StoplessArguments::initialize() {
+  GCArguments::initialize();
+  assert(UseStoplessGC, "Sanity");
+
+  // No JIT-side patching needed: the CHERI cap-tag check on every
+  // oop load IS the read barrier. Stopless does not require ParallelGC-
+  // style remembered sets or G1-style SATB queues.
+}
+
+CollectedHeap* StoplessArguments::create_heap() {
+  return new StoplessHeap();
+}
