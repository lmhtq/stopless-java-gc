diff --git a/src/hotspot/share/gc/stopless/stoplessBarrierSet.hpp b/src/hotspot/share/gc/stopless/stoplessBarrierSet.hpp
new file mode 100644
index 00000000000..e22144cfd01
--- /dev/null
+++ b/src/hotspot/share/gc/stopless/stoplessBarrierSet.hpp
@@ -0,0 +1,53 @@
+/*
+ * Copyright (c) 2026, bluecat. CHERI-Stopless GC for OpenJDK.
+ *
+ * Phase C-1 skeleton — see docs/c1/design.md.
+ *
+ * Read barrier rationale:
+ *   The CHERI capability tag bit is checked by every cap-load/store
+ *   instruction in hardware. When the collector revokes a stale cap,
+ *   the next mutator access traps SIGPROT and our handler forwards.
+ *   No software-emitted read barrier is required, so all AccessBarrier
+ *   load entry points fall through to BasicAccess.
+ *
+ * Write barrier rationale (v1):
+ *   Reference stores into objects in the "evacuating" region need to
+ *   be redirected. C-10 will replace this with either a card-mark or
+ *   a mprotect-based RO trap. For C-1 the write path is a NOP.
+ */
+
+#ifndef SHARE_GC_STOPLESS_STOPLESSBARRIERSET_HPP
+#define SHARE_GC_STOPLESS_STOPLESSBARRIERSET_HPP
+
+#include "gc/shared/barrierSet.hpp"
+#include "gc/shared/barrierSetAssembler.hpp"
+
+class StoplessBarrierSet : public BarrierSet {
+ public:
+  StoplessBarrierSet();
+
+  void on_thread_create(Thread* thread) override   { }
+  void on_thread_destroy(Thread* thread) override  { }
+  void on_thread_attach(Thread* thread) override   { }
+  void on_thread_detach(Thread* thread) override   { }
+
+  void print_on(outputStream* st) const override;
+
+  template <DecoratorSet decorators, typename BarrierSetT = StoplessBarrierSet>
+  class AccessBarrier : public BarrierSet::AccessBarrier<decorators, BarrierSetT> {
+    // Inherits all default behaviour from BasicAccess. CHERI hw handles
+    // the read-barrier path; v1 has no write-barrier filtering.
+  };
+};
+
+template<>
+struct BarrierSet::GetName<StoplessBarrierSet> {
+  static const BarrierSet::Name value = BarrierSet::StoplessBarrierSet;
+};
+
+template<>
+struct BarrierSet::GetType<BarrierSet::StoplessBarrierSet> {
+  typedef ::StoplessBarrierSet type;
+};
+
+#endif // SHARE_GC_STOPLESS_STOPLESSBARRIERSET_HPP
diff --git a/src/hotspot/share/gc/stopless/stoplessHeap.cpp b/src/hotspot/share/gc/stopless/stoplessHeap.cpp
new file mode 100644
index 00000000000..069115be038
--- /dev/null
+++ b/src/hotspot/share/gc/stopless/stoplessHeap.cpp
@@ -0,0 +1,75 @@
+/*
+ * Copyright (c) 2026, bluecat. CHERI-Stopless GC for OpenJDK.
+ *
+ * Phase C-1 skeleton — see docs/c1/design.md.
+ */
+
+#include "precompiled.hpp"
+#include "gc/stopless/stoplessHeap.hpp"
+#include "gc/stopless/stoplessBarrierSet.hpp"
+#include "gc/shared/gcArguments.hpp"
+#include "memory/universe.hpp"
+#include "runtime/globals.hpp"
+#include "gc/shared/gc_globals.hpp"
+#include "gc/shared/tlab_globals.hpp"
+#include "utilities/ostream.hpp"
+
+StoplessHeap* StoplessHeap::heap() {
+  CollectedHeap* heap = Universe::heap();
+  assert(heap != nullptr, "Uninitialized access to StoplessHeap::heap()");
+  assert(heap->kind() == CollectedHeap::Stopless, "Not a StoplessHeap");
+  return (StoplessHeap*)heap;
+}
+
+StoplessHeap::StoplessHeap()
+  : _soft_ref_policy(),
+    _barrier_set(nullptr),
+    _arena_capacity(0),
+    _arena_used(0) {
+}
+
+jint StoplessHeap::initialize() {
+  // v1: no TLAB. Java alloc goes straight through mem_allocate.
+  UseTLAB = false;
+  // Phase C-3 will mmap the actual arena via cap_runtime/stopless_arena_init.
+  // For C-1 we just record the requested sizes so the JVM proceeds.
+  size_t min_byte_size = MAX2(MinHeapSize, (size_t)4 * M);
+  size_t max_byte_size = MAX2(MaxHeapSize, min_byte_size);
+  _arena_capacity = max_byte_size;
+  _arena_used     = 0;
+
+  // Install our (NOP) barrier set so BarrierSet::barrier_set() returns
+  // something non-null. Real read/write barriers are no-ops in C-1
+  // because the CHERI cap-tag check IS the barrier.
+  _barrier_set = new StoplessBarrierSet();
+  BarrierSet::set_barrier_set(_barrier_set);
+
+  return JNI_OK;
+}
+
+bool StoplessHeap::is_in(const void* p) const {
+  // v1: arena not yet allocated. C-3 will replace this.
+  (void)p;
+  return false;
+}
+
+HeapWord* StoplessHeap::mem_allocate(size_t size,
+                                     bool* gc_overhead_limit_was_exceeded) {
+  // C-4 fills in. For C-1 we return nullptr so the caller raises OOM
+  // gracefully rather than crashing — useful when running -version
+  // without ever needing to actually allocate.
+  (void)size;
+  if (gc_overhead_limit_was_exceeded != nullptr) {
+    *gc_overhead_limit_was_exceeded = false;
+  }
+  return nullptr;
+}
+
+void StoplessHeap::print_on(outputStream* st) const {
+  st->print_cr("Stopless Heap (CHERI-accelerated, Phase C-1 skeleton)");
+  st->print_cr("  capacity %zuK, used %zuK",
+               _arena_capacity / K, _arena_used / K);
+  if (_barrier_set != nullptr) {
+    _barrier_set->print_on(st);
+  }
+}
diff --git a/src/hotspot/share/gc/stopless/stoplessHeap.hpp b/src/hotspot/share/gc/stopless/stoplessHeap.hpp
new file mode 100644
index 00000000000..324b638739c
--- /dev/null
+++ b/src/hotspot/share/gc/stopless/stoplessHeap.hpp
@@ -0,0 +1,94 @@
+/*
+ * Copyright (c) 2026, bluecat. CHERI-Stopless GC for OpenJDK.
+ *
+ * Phase C-1 skeleton — see docs/c1/design.md.
+ */
+
+#ifndef SHARE_GC_STOPLESS_STOPLESSHEAP_HPP
+#define SHARE_GC_STOPLESS_STOPLESSHEAP_HPP
+
+#include "gc/shared/collectedHeap.hpp"
+#include "gc/shared/softRefPolicy.hpp"
+#include "memory/virtualspace.hpp"
+#include "services/memoryManager.hpp"
+#include "services/memoryPool.hpp"
+#include "utilities/growableArray.hpp"
+
+class StoplessBarrierSet;
+
+// The Stopless heap is a single contiguous arena of CHERI-tagged
+// memory. v1 has no allocator (C-4 adds bump-pointer) and no collector
+// (C-9 adds the concurrent mover). This skeleton exists so the GC
+// machinery can be configured at JVM launch with -XX:+UseStoplessGC
+// and the JVM proceeds far enough to test the wire-up.
+
+class StoplessHeap : public CollectedHeap {
+  friend class VMStructs;
+ private:
+  SoftRefPolicy        _soft_ref_policy;
+  StoplessBarrierSet*  _barrier_set;
+  size_t               _arena_capacity;
+  size_t               _arena_used;
+
+ public:
+  static StoplessHeap* heap();
+
+  StoplessHeap();
+
+  // ---- CollectedHeap virtuals (minimal stubs for Phase C-1) -------
+
+  Name kind() const override          { return CollectedHeap::Stopless; }
+  const char* name() const override   { return "Stopless"; }
+
+  SoftRefPolicy* soft_ref_policy() override { return &_soft_ref_policy; }
+
+  jint initialize() override;
+  void post_initialize() override     { CollectedHeap::post_initialize(); }
+  void initialize_serviceability() override { /* C-7 */ }
+
+  size_t capacity() const override     { return _arena_capacity; }
+  size_t used() const override         { return _arena_used; }
+  size_t max_capacity() const override { return _arena_capacity; }
+
+  bool is_in(const void* p) const override;
+  bool is_maximal_no_gc() const override { return true; }
+
+  HeapWord* mem_allocate(size_t size,
+                         bool* gc_overhead_limit_was_exceeded) override;
+
+  void collect(GCCause::Cause cause) override            { /* C-9 */ }
+  void do_full_collection(bool clear_all_soft_refs) override { /* v1 no-op */ }
+
+  void object_iterate(ObjectClosure* cl) override        { ShouldNotReachHere(); }
+  
+  size_t tlab_capacity(Thread* thr) const override        { return 0; }
+  size_t tlab_used(Thread* thr) const override            { return 0; }
+
+  GrowableArray<GCMemoryManager*> memory_managers() override { return GrowableArray<GCMemoryManager*>(); }
+  GrowableArray<MemoryPool*> memory_pools() override         { return GrowableArray<MemoryPool*>(); }
+
+  // Stubs for required virtuals — Phase C v1 doesn't need real impls.
+  bool print_location(outputStream* st, void* addr) const override { return false; }
+  void gc_threads_do(ThreadClosure* tc) const override              { /* no extra threads */ }
+  void register_nmethod(nmethod* nm) override                       { }
+  void unregister_nmethod(nmethod* nm) override                     { }
+  void flush_nmethod(nmethod* nm) override                          { }
+  void verify_nmethod(nmethod* nm) override                         { }
+
+  void print_on(outputStream* st) const override;
+  void print_tracing_info() const override               { /* no-op */ }
+
+  void prepare_for_verify() override                     { /* no-op */ }
+  void verify(VerifyOption option) override              { /* no-op */ }
+
+  jlong millis_since_last_gc()                  { return 0; }
+
+  HeapWord* block_start(const void* addr) const { return nullptr; }
+  bool block_is_obj(const HeapWord* addr) const { return false; }
+
+  // -----------------------------------------------------------------
+
+  StoplessBarrierSet* barrier_set() const { return _barrier_set; }
+};
+
+#endif // SHARE_GC_STOPLESS_STOPLESSHEAP_HPP
