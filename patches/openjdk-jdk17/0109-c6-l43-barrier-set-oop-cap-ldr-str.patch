@@ -699,16 +741,188 @@ public:
   // Alignment
   void align(int modulus);
 
+#ifdef __CHERI_PURE_CAPABILITY__
+  // C-6 fix #12 helpers: emit Morello cap-STR and cap-STP directly.
+  // HotSpot's Assembler::str/stp emit integer encodings (0xf9xxxxxx /
+  // 0xa9xxxxxx) that are either illegal in C64 mode or silently drop
+  // cap tags. Cap variants: 0xC2 (STR), 0xA2 (STUR), 0x42 (STP).
+  // Verified vs Morello clang (see docs/27 + docs/28).
+  // Use these explicitly in stubs where the register holds a cap.
+
+  // str Ct, [Cn, #imm]   (cap, 16-byte, signed-offset)
+  inline void cap_str_imm(Register Ct, Register Cn, int imm) {
+    if (imm >= 0 && (imm % 16) == 0 && imm < 16 * 4096) {
+      // STR (immediate, unsigned offset): imm12 scaled by 16.
+      emit_int32(0xC2000000U | (((unsigned)imm / 16) << 10)
+                 | (Cn->encoding() << 5) | Ct->encoding());
+    } else {
+      // STUR (immediate, signed 9-bit unscaled).
+      emit_int32(0xA2000000U | (((unsigned)imm & 0x1FF) << 12)
+                 | (Cn->encoding() << 5) | Ct->encoding());
+    }
+  }
+  // stp Ct, Ct2, [Cn, #imm]   (cap-pair, 32 bytes total, signed-offset)
+  inline void cap_stp_imm(Register Ct, Register Ct2, Register Cn, int imm) {
+    // imm7 = imm/16 (signed 7-bit), scaled by 16.
+    emit_int32(0x42800000U | ((((unsigned)imm / 16) & 0x7F) << 15)
+               | (Ct2->encoding() << 10) | (Cn->encoding() << 5)
+               | Ct->encoding());
+  }
+  // ldr Ct, [Cn, #imm]   (cap, 16-byte, signed-offset)
+  inline void cap_ldr_imm(Register Ct, Register Cn, int imm) {
+    if (imm >= 0 && (imm % 16) == 0 && imm < 16 * 4096) {
+      emit_int32(0xC2400000U | (((unsigned)imm / 16) << 10)
+                 | (Cn->encoding() << 5) | Ct->encoding());
+    } else {
+      emit_int32(0xA2400000U | (((unsigned)imm & 0x1FF) << 12)
+                 | (Cn->encoding() << 5) | Ct->encoding());
+    }
+  }
+  // ldp Ct, Ct2, [Cn, #imm]   (cap-pair, 32 bytes total, signed-offset)
+  inline void cap_ldp_imm(Register Ct, Register Ct2, Register Cn, int imm) {
+    emit_int32(0x42C00000U | ((((unsigned)imm / 16) & 0x7F) << 15)
+               | (Ct2->encoding() << 10) | (Cn->encoding() << 5)
+               | Ct->encoding());
+  }
+  // sub Cd, Cn, #imm12   (cap-sub immediate)
+  inline void cap_sub_imm(Register Cd, Register Cn, unsigned imm12) {
+    unsigned rd_enc = (Cd == sp) ? 31u : (unsigned)Cd->encoding();
+    unsigned rn_enc = (Cn == sp) ? 31u : (unsigned)Cn->encoding();
+    emit_int32(0x02800000U | ((imm12 & 0xFFF) << 10) | (rn_enc << 5) | rd_enc);
+  }
+  // add Cd, Cn, #imm12   (cap-add immediate, preserves cap metadata)
+  inline void cap_add_imm(Register Cd, Register Cn, unsigned imm12) {
+    unsigned rd_enc = (Cd == sp) ? 31u : (unsigned)Cd->encoding();
+    unsigned rn_enc = (Cn == sp) ? 31u : (unsigned)Cn->encoding();
+    emit_int32(0x02000000U | ((imm12 & 0xFFF) << 10) | (rn_enc << 5) | rd_enc);
+  }
+  // blr Cn   (Morello "Branch with Link to Capability"). UNLIKE the
+  // integer `blr Xn` (0xd63f0000-family) which only updates PC within
+  // the CURRENT PCC bounds, this installs Cn as the NEW PCC. Required
+  // for any call whose target lies OUTSIDE the caller's PCC bounds —
+  // e.g. a codecache stub calling into libjvm.so .text. Verified vs
+  // Morello clang: `blr c0` = 0xC2C23000, so `blr cN` = 0xC2C23000 |
+  // (Rn<<5). (Cf. `ret c30` = 0xC2C253C0 = 0xC2C25000 | (30<<5).)
+  inline void cap_blr(Register Cn) {
+    emit_int32(0xC2C23000U | ((unsigned)Cn->encoding() << 5));
+  }
+  // br Cn    (Morello cap branch, no link). `br c0` = 0xC2C21000.
+  inline void cap_br(Register Cn) {
+    emit_int32(0xC2C21000U | ((unsigned)Cn->encoding() << 5));
+  }
+  // Capability load/store dispatching on the Address mode — for oop
+  // (16-byte capability) access in the GC barrier set. base_plus_offset
+  // uses the imm form; base_plus_offset_reg uses the scaled register
+  // form `ldr/str Ct, [Cn, Xm, lsl #4]` (×16 = cap element size, correct
+  // for uncompressed-oop arrays). Verified vs Morello clang:
+  //   ldr c0,[c0,x1,lsl#4] = 0xA2617800 → 0xA2607800 | Xm<<16 | Cn<<5 | Ct
+  //   str c2,[c0,x1,lsl#4] = 0xA2217802 → 0xA2207800 | Xm<<16 | Cn<<5 | Ct
+  // S (bit 12) selects scaled (lsl #log2(16), for oop array elements,
+  //   ldr c,[c,x,lsl#4]=0xA2617800) vs unscaled (uxtx, for byte-offset
+  //   field access, ldr c,[c,x]=0xA2616800). S = (index_shift() > 0).
+  inline void cap_ldr(Register dst, const Address& a) {
+    if (a.getMode() == Address::base_plus_offset) {
+      cap_ldr_imm(dst, a.base(), (int)a.offset());
+    } else {
+      unsigned S = (a.index_shift() > 0) ? 1u : 0u;
+      emit_int32(0xA2606800U | (S << 12) | ((unsigned)a.index()->encoding() << 16)
+                 | ((unsigned)a.base()->encoding() << 5) | (unsigned)dst->encoding());
+    }
+  }
+  inline void cap_str(Register src, const Address& a) {
+    if (a.getMode() == Address::base_plus_offset) {
+      cap_str_imm(src, a.base(), (int)a.offset());
+    } else {
+      unsigned S = (a.index_shift() > 0) ? 1u : 0u;
+      emit_int32(0xA2206800U | (S << 12) | ((unsigned)a.index()->encoding() << 16)
+                 | ((unsigned)a.base()->encoding() << 5) | (unsigned)src->encoding());
+    }
+  }
+  // add Cd, Cn, Xm  (Morello cap + 64-bit register, preserves Cn's cap
+  // metadata/bounds/tag and adds Xm to the address). The stock
+  // Assembler::add(Cd, Cn, Rm, LSL, n) emits an INTEGER add that strips
+  // the cap tag. Verified vs Morello clang: `add c0,c0,x1,uxtx` =
+  // 0xC2A16000, so `add Cd,Cn,Xm,uxtx` = 0xC2A06000 | (Xm<<16) | (Cn<<5)
+  // | Cd. Caller pre-shifts Xm if a scaled index is needed.
+  inline void cap_add_reg(Register Cd, Register Cn, Register Xm) {
+    emit_int32(0xC2A06000U | ((unsigned)Xm->encoding() << 16)
+               | ((unsigned)Cn->encoding() << 5) | (unsigned)Cd->encoding());
+  }
+  // cap-STP to [sp, #imm] (no writeback). The stack pointer encodes as
+  // register #31 in instructions — HotSpot's `sp` Register* has a pseudo
+  // encoding (#33) so we MUST hardcode 31 here, not sp->encoding(). The
+  // zero register zr also encodes as #31 in the Rt fields → stores a
+  // null cap, which is the intent for the zr operands. Cap-pair = 32B,
+  // 16-byte slot stride (matches the interpreter frame's cap-sized slots).
+  inline void cap_stp_sp(Register Ct, Register Ct2, int imm) {
+    emit_int32(0x42800000U | ((((unsigned)imm / 16) & 0x7F) << 15)
+               | ((unsigned)Ct2->encoding() << 10) | (31U << 5)
+               | (unsigned)Ct->encoding());
+  }
+  // cap-STP pre-index [sp, #imm]! (writeback). Pre-index family = 0x62800000.
+  inline void cap_stp_sp_pre(Register Ct, Register Ct2, int imm) {
+    emit_int32(0x62800000U | ((((unsigned)imm / 16) & 0x7F) << 15)
+               | ((unsigned)Ct2->encoding() << 10) | (31U << 5)
+               | (unsigned)Ct->encoding());
+  }
+  // dst = a valid capability addressing the libjvm.so global `target`.
+  // PCC-relative ADRP from the codecache produces a cap with codecache
+  // bounds that cannot reach libjvm.so data/bss (PROT_CHERI_BOUNDS) —
+  // the data analog of the cap-BLR problem. We instead derive from DDC
+  // (Default Data Capability), which spans the whole data address space,
+  // then SCVALUE its address to `target`. `tmp` is clobbered with the
+  // integer target address.
+  //   mrs   dst, DDC                 (0xC29B4120 | dst)
+  //   mov   tmp, #target             (movz/movk sequence)
+  //   scvalue dst, dst, tmp          (0xC2C14000 | tmp<<16 | dst<<5 | dst)
+  inline void cap_lea_global(Register dst, address target, Register tmp) {
+    emit_int32(0xC29B4120U | (unsigned)dst->encoding());
+    mov(tmp, (uint64_t)(uintptr_t)target);
+    emit_int32(0xC2C14000U | ((unsigned)tmp->encoding() << 16)
+               | ((unsigned)dst->encoding() << 5) | (unsigned)dst->encoding());
+  }
+#endif
+
   // Stack frame creation/removal
   void enter()
   {
+#ifdef __CHERI_PURE_CAPABILITY__
+    // C-6 fix #9: emit Morello cap-stp + cap-mov in stack frame setup.
+    // The standard AArch64 STP (0xA9...) emitted by stp(Reg,Reg,Address)
+    // is INTEGER stp — it stores 8-byte pairs and clears the cap tag
+    // of rfp/lr in the destination memory. The Morello cap-STP
+    // (0x62800000-family) stores 16-byte cap pairs preserving tags.
+    // Encoding (cap-stp pre-imm): 0x62800000 | ((imm7) << 15)
+    //                              | (Rt2<<10) | (Rn<<5) | Rt
+    // where imm7 = byte_offset / 16 (signed 7-bit).
+    // For -2*wordSize = -32 bytes, imm7 = -2 = 0x7E (7-bit signed).
+    //   0x62800000 | (0x7E << 15) | (30<<10) | (31<<5) | 29 = 0x62BF7BFD
+    // Note: SP/CSP encodes as register #31 in instructions (not the
+    // pseudo #33 used as HotSpot's `sp` Register*).
+    emit_int32(0x62800000 | ((-32/16 & 0x7F) << 15) |
+               (30 << 10) | (31 << 5) | 29);
+    // mov(rfp, sp) — emit cap-add #0 from csp.
+    //   0x02000000 | (0<<22) | (0<<10) | (31<<5) | 29 = 0x020003FD
+    emit_int32(0x02000000 | (31 << 5) | 29);
+#else
     stp(rfp, lr, Address(pre(sp, -2 * wordSize)));
     mov(rfp, sp);
+#endif
   }
   void leave()
   {
+#ifdef __CHERI_PURE_CAPABILITY__
+    // mirror of enter(): cap-add sp,rfp,#0 then cap-ldp post-imm +32
+    //   0x02000000 | (29 << 5) | 31 = 0x020003BF (sp <- rfp + 0)
+    emit_int32(0x02000000 | (29 << 5) | 31);
+    // cap-ldp post-imm: 0x22C00000 | ((imm7) << 15) | (Rt2<<10) | (Rn<<5) | Rt
+    //   0x22C00000 | (2 << 15) | (30<<10) | (31<<5) | 29 = 0x22C17BFD
+    emit_int32(0x22C00000 | ((32/16 & 0x7F) << 15) |
+               (30 << 10) | (31 << 5) | 29);
+#else
     mov(sp, rfp);
     ldp(rfp, lr, Address(post(sp, 2 * wordSize)));
+#endif
   }
 
   // Support for getting the JavaThread pointer (i.e.; a reference to thread-local information)
@@ -1013,8 +1227,25 @@ public:
   void bang_stack_with_offset(int offset) {
     // stack grows down, caller passes positive offset
     assert(offset > 0, "must bang with negative offset");
+#ifdef __CHERI_PURE_CAPABILITY__
+    // C-6 fix #31: integer sub(rscratch2, sp, offset) strips sp's cap
+    // tag, so the str below faults PROT_CHERI_TAG. Use cap-SUB to keep
+    // the stack capability. sp encodes as #31. Handle both the imm12
+    // and the LSL #12 (page-multiple) forms.
+    unsigned rd = (unsigned)rscratch2->encoding();
+    if (offset < (1 << 12)) {
+      emit_int32(0x02800000U | ((unsigned)offset << 10) | (31U << 5) | rd);
+    } else {
+      assert((offset & 0xFFF) == 0 && (unsigned)(offset >> 12) < (1U << 12),
+             "bang offset not representable as cap-SUB imm12<<12");
+      emit_int32(0x02800000U | (1U << 22)
+                 | (((unsigned)offset >> 12) << 10) | (31U << 5) | rd);
+    }
+    str(zr, Address(rscratch2));
+#else
     sub(rscratch2, sp, offset);
     str(zr, Address(rscratch2));
+#endif
   }
 
