From: bluecat <lmhtq1991@gmail.com>
Date: Wed, 27 May 2026 21:30:00 +0800
Subject: [PATCH] Phase C-2: wire StoplessGC into JVM build + flag system

Pairs with 0080. After both apply, the JVM:
- recognizes -XX:+UseStoplessGC as a valid product flag
- prints "stopless gc" in -version banner when selected
- routes StoplessHeap as the active CollectedHeap

8 files modified:
- gc/shared/collectedHeap.hpp        : enum Name += Stopless
- gc/shared/barrierSetConfig.hpp     : STOPLESSGC_ONLY(f(StoplessBarrierSet))
- gc/shared/barrierSetConfig.inline.hpp : include stoplessBarrierSet.hpp
- gc/shared/gc_globals.hpp           : include + UseStoplessGC product flag
- gc/shared/gcConfig.cpp             : register Stopless in IncludedGCs
- utilities/macros.hpp               : STOPLESSGC_ONLY / NOT_STOPLESSGC
- make/hotspot/lib/JvmFeatures.gmk   : stoplessgc feature + cap_runtime link
- make/autoconf/jvm-features.m4      : stoplessgc in valid features

Note: spec.gmk also needs `VALID_JVM_FEATURES` regenerated by re-running
`bash configure`. As a workaround, scripts/apply_stoplessgc_to_openjdk.py
patches spec.gmk in-place for the existing build dir.

Design: docs/c2/design.md
Overview: docs/17_phase_c_overview.md

diff --git a/make/autoconf/jvm-features.m4 b/make/autoconf/jvm-features.m4
index aa99b037b2b..33d3ff1b745 100644
--- a/make/autoconf/jvm-features.m4
+++ b/make/autoconf/jvm-features.m4
@@ -44,7 +44,7 @@
 m4_define(jvm_features_valid, m4_normalize( \
     ifdef([custom_jvm_features_valid], custom_jvm_features_valid) \
     \
-    cds compiler1 compiler2 dtrace epsilongc g1gc jfr jni-check \
+    cds compiler1 compiler2 dtrace epsilongc stoplessgc g1gc jfr jni-check \
     jvmci jvmti link-time-opt management minimal nmt opt-size parallelgc \
     serialgc services shenandoahgc static-build vm-structs zero zgc \
 ))
@@ -60,6 +60,7 @@ m4_define(jvm_feature_desc_compiler1, [enable hotspot compiler C1])
 m4_define(jvm_feature_desc_compiler2, [enable hotspot compiler C2])
 m4_define(jvm_feature_desc_dtrace, [enable dtrace support])
 m4_define(jvm_feature_desc_epsilongc, [include the epsilon (no-op) garbage collector])
+m4_define(jvm_feature_desc_stoplessgc, [include the Stopless (CHERI-accelerated) garbage collector])
 m4_define(jvm_feature_desc_g1gc, [include the G1 garbage collector])
 m4_define(jvm_feature_desc_jfr, [enable JDK Flight Recorder (JFR)])
 m4_define(jvm_feature_desc_jni_check, [enable -Xcheck:jni support])
diff --git a/make/hotspot/lib/JvmFeatures.gmk b/make/hotspot/lib/JvmFeatures.gmk
index 1f16d0a9118..305bf719f60 100644
--- a/make/hotspot/lib/JvmFeatures.gmk
+++ b/make/hotspot/lib/JvmFeatures.gmk
@@ -149,6 +149,21 @@ ifneq ($(call check-jvm-feature, epsilongc), true)
   JVM_EXCLUDE_PATTERNS += gc/epsilon
 endif
 
+ifneq ($(call check-jvm-feature, stoplessgc), true)
+  JVM_CFLAGS_FEATURES += -DINCLUDE_STOPLESSGC=0
+  JVM_EXCLUDE_PATTERNS += gc/stopless
+else
+  JVM_CFLAGS_FEATURES += -DINCLUDE_STOPLESSGC=1
+  STOPLESS_RUNTIME_DIR ?= $(TOPDIR)/../cap_runtime/stopless_gc
+  ifneq ($(wildcard $(STOPLESS_RUNTIME_DIR)/libstopless_gc.a),)
+    JVM_LIBS_FEATURES += $(STOPLESS_RUNTIME_DIR)/libstopless_gc.a -lcheri_caprevoke
+    JVM_CFLAGS_FEATURES += -I$(STOPLESS_RUNTIME_DIR)
+  else
+    $(warning STOPLESSGC enabled but $(STOPLESS_RUNTIME_DIR)/libstopless_gc.a not built)
+    $(warning Run: gmake -C $(STOPLESS_RUNTIME_DIR) CROSS=1)
+  endif
+endif
+
 ifneq ($(call check-jvm-feature, zgc), true)
   JVM_CFLAGS_FEATURES += -DINCLUDE_ZGC=0
   JVM_EXCLUDE_PATTERNS += gc/z
diff --git a/src/hotspot/share/gc/shared/barrierSetConfig.hpp b/src/hotspot/share/gc/shared/barrierSetConfig.hpp
index e20e9ef6f7c..d6ea034f4d0 100644
--- a/src/hotspot/share/gc/shared/barrierSetConfig.hpp
+++ b/src/hotspot/share/gc/shared/barrierSetConfig.hpp
@@ -33,7 +33,8 @@
   EPSILONGC_ONLY(f(EpsilonBarrierSet))               \
   G1GC_ONLY(f(G1BarrierSet))                         \
   SHENANDOAHGC_ONLY(f(ShenandoahBarrierSet))         \
-  ZGC_ONLY(f(ZBarrierSet))
+  ZGC_ONLY(f(ZBarrierSet))                           \
+  STOPLESSGC_ONLY(f(StoplessBarrierSet))
 
 #define FOR_EACH_ABSTRACT_BARRIER_SET_DO(f)          \
   f(ModRef)
