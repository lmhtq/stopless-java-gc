 }
 
 jint StoplessHeap::initialize() {
   // v1: no TLAB. Java alloc goes straight through mem_allocate.
   UseTLAB = false;
-  // Phase C-3 will mmap the actual arena via cap_runtime/stopless_arena_init.
-  // For C-1 we just record the requested sizes so the JVM proceeds.
-  size_t min_byte_size = MAX2(MinHeapSize, (size_t)4 * M);
-  size_t max_byte_size = MAX2(MaxHeapSize, min_byte_size);
-  _arena_capacity = max_byte_size;
-  _arena_used     = 0;
+  // Floor 4 MiB to avoid degenerate small heaps.
+  size_t max_byte_size = MAX2(MaxHeapSize, (size_t)4 * M);
+
+  // Allocate the real CHERI-backed arena via cap_runtime. Aborts the
+  // VM (vm_exit_during_initialization) on mmap/shadow failure.
+  _arena = new StoplessArena(max_byte_size);
 
   // Install our (NOP) barrier set so BarrierSet::barrier_set() returns
-  // something non-null. Real read/write barriers are no-ops in C-1
+  // something non-null. Real read/write barriers are no-ops in v1
   // because the CHERI cap-tag check IS the barrier.
   _barrier_set = new StoplessBarrierSet();
   BarrierSet::set_barrier_set(_barrier_set);
@@ -48,27 +49,53 @@ jint StoplessHeap::initialize() {
 }
 
 bool StoplessHeap::is_in(const void* p) const {
-  // v1: arena not yet allocated. C-3 will replace this.
-  (void)p;
-  return false;
+  return _arena != nullptr && _arena->contains(p);
 }
 
 HeapWord* StoplessHeap::mem_allocate(size_t size,
                                      bool* gc_overhead_limit_was_exceeded) {
-  // C-4 fills in. For C-1 we return nullptr so the caller raises OOM
-  // gracefully rather than crashing — useful when running -version
-  // without ever needing to actually allocate.
-  (void)size;
   if (gc_overhead_limit_was_exceeded != nullptr) {
     *gc_overhead_limit_was_exceeded = false;
   }
-  return nullptr;
+  if (_arena == nullptr) return nullptr;
+
+  // `size` is in HeapWords. On CHERI purecap HeapWordSize=16 (patch
+  // 0060). Convert to bytes for the bump allocator.
+  size_t bytes = size * HeapWordSize;
+  void*  p     = _arena->allocate(bytes);
+
+  if (p == nullptr) {
+    // OOM. C-9 will trigger a concurrent collection here and retry.
+    // v1: just propagate OOM upward.
+    log_warning(gc)("StoplessHeap: alloc(%zu bytes) returned nullptr "
+                    "(used=%zuK / cap=%zuK)",
+                    bytes,
+                    _arena->used() / K,
+                    _arena->capacity() / K);
+    return nullptr;
+  }
+  return (HeapWord*)p;
+}
+
+size_t StoplessHeap::capacity() const {
+  return _arena != nullptr ? _arena->capacity() : 0;
+}
+
+size_t StoplessHeap::used() const {
+  return _arena != nullptr ? _arena->used() : 0;
+}
+
+size_t StoplessHeap::max_capacity() const {
+  return _arena != nullptr ? _arena->capacity() : 0;
 }
 
 void StoplessHeap::print_on(outputStream* st) const {
-  st->print_cr("Stopless Heap (CHERI-accelerated, Phase C-1 skeleton)");
-  st->print_cr("  capacity %zuK, used %zuK",
-               _arena_capacity / K, _arena_used / K);
+  st->print_cr("Stopless Heap (CHERI-accelerated)");
+  if (_arena != nullptr) {
+    _arena->print_on(st);
+  } else {
+    st->print_cr("  <arena not initialized>");
+  }
   if (_barrier_set != nullptr) {
     _barrier_set->print_on(st);
   }
