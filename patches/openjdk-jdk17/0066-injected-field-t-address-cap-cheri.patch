index 052d013368a..81dbae06dc3 100644
--- a/src/hotspot/share/classfile/classFileParser.cpp
+++ b/src/hotspot/share/classfile/classFileParser.cpp
@@ -1371,6 +1371,8 @@ enum FieldAllocationType {
   NONSTATIC_SHORT,
   NONSTATIC_WORD,
   NONSTATIC_DOUBLE,
+  STATIC_ADDRESS,       /* CHERI: T_ADDRESS, sized sizeof(intptr_t) */
+  NONSTATIC_ADDRESS,
   MAX_FIELD_ALLOCATION_TYPE,
   BAD_ALLOCATION_TYPE = -1
 };
@@ -1391,7 +1393,7 @@ static FieldAllocationType _basic_type_to_atype[2 * (T_CONFLICT + 1)] = {
   NONSTATIC_OOP,       // T_OBJECT      = 12,
   NONSTATIC_OOP,       // T_ARRAY       = 13,
   BAD_ALLOCATION_TYPE, // T_VOID        = 14,
-  BAD_ALLOCATION_TYPE, // T_ADDRESS     = 15,
+  NONSTATIC_ADDRESS,   // T_ADDRESS     = 15,  /* CHERI cap-typed field */
   BAD_ALLOCATION_TYPE, // T_NARROWOOP   = 16,
   BAD_ALLOCATION_TYPE, // T_METADATA    = 17,
   BAD_ALLOCATION_TYPE, // T_NARROWKLASS = 18,
@@ -1411,7 +1413,7 @@ static FieldAllocationType _basic_type_to_atype[2 * (T_CONFLICT + 1)] = {
   STATIC_OOP,          // T_OBJECT      = 12,
   STATIC_OOP,          // T_ARRAY       = 13,
   BAD_ALLOCATION_TYPE, // T_VOID        = 14,
-  BAD_ALLOCATION_TYPE, // T_ADDRESS     = 15,
+  STATIC_ADDRESS,      // T_ADDRESS     = 15,  /* CHERI cap-typed static field */
   BAD_ALLOCATION_TYPE, // T_NARROWOOP   = 16,
   BAD_ALLOCATION_TYPE, // T_METADATA    = 17,
   BAD_ALLOCATION_TYPE, // T_NARROWKLASS = 18,
@@ -1419,7 +1421,8 @@ static FieldAllocationType _basic_type_to_atype[2 * (T_CONFLICT + 1)] = {
 };

 static FieldAllocationType basic_type_to_atype(bool is_static, BasicType type) {
-  assert(type >= T_BOOLEAN && type < T_VOID, "only allowable values");
+  /* CHERI: T_ADDRESS now a valid field type for cap-sized injected fields. */
+  assert((type >= T_BOOLEAN && type < T_VOID) || type == T_ADDRESS, "only allowable values");
   FieldAllocationType result = _basic_type_to_atype[type + (is_static ? (T_CONFLICT + 1) : 0)];
   assert(result != BAD_ALLOCATION_TYPE, "bad type");
   return result;
@@ -4874,6 +4877,7 @@ const char* ClassFileParser::skip_over_field_signature(const char* signature,
     case JVM_SIGNATURE_FLOAT:
     case JVM_SIGNATURE_LONG:
     case JVM_SIGNATURE_DOUBLE:
+    case JVM_SIGNATURE_ADDRESS:  /* CHERI: T_ADDRESS field signature */
       return signature + 1;
     case JVM_SIGNATURE_CLASS: {
       if (_major_version < JAVA_1_5_VERSION) {
diff --git a/src/hotspot/share/classfile/fieldLayoutBuilder.cpp b/src/hotspot/share/classfile/fieldLayoutBuilder.cpp
index 0a5314d5ea3..0df05a90367 100644
--- a/src/hotspot/share/classfile/fieldLayoutBuilder.cpp
+++ b/src/hotspot/share/classfile/fieldLayoutBuilder.cpp
@@ -578,6 +578,10 @@ void FieldLayoutBuilder::regular_field_sorting() {
       case T_BOOLEAN:
         group->add_primitive_field(fs, type);
         break;
+      case T_ADDRESS:
+        /* CHERI: T_ADDRESS holds a capability; size = sizeof(intptr_t). */
+        group->add_primitive_field(fs, type);
+        break;
       case T_OBJECT:
       case T_ARRAY:
         if (group != _static_fields) _nonstatic_oopmap_count++;
