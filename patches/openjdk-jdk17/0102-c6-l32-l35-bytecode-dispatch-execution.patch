+  // for any call whose target lies OUTSIDE the caller's PCC bounds —
+  // e.g. a codecache stub calling into libjvm.so .text. Verified vs
+  // Morello clang: `blr c0` = 0xC2C23000, so `blr cN` = 0xC2C23000 |
+  // (Rn<<5). (Cf. `ret c30` = 0xC2C253C0 = 0xC2C25000 | (30<<5).)
+  inline void cap_blr(Register Cn) {
+    emit_int32(0xC2C23000U | ((unsigned)Cn->encoding() << 5));
+  }
+  // br Cn    (Morello cap branch, no link). `br c0` = 0xC2C21000.
+  inline void cap_br(Register Cn) {
+    emit_int32(0xC2C21000U | ((unsigned)Cn->encoding() << 5));
