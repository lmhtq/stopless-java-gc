+#ifdef __CHERI_PURE_CAPABILITY__
+      // C-6 fix #13: mov(Reg, sp) / mov(sp, Reg) — Assembler::add emits
+      // INTEGER ADD (0x91xxxxxx) which doesn't preserve cap tag. Emit
+      // Morello cap-ADD (0x02000000-family) directly. sp/csp encodes as
+      // register #31 in instructions.
+      unsigned rd_enc = (Rd == sp) ? 31u : (unsigned)Rd->encoding();
+      unsigned rn_enc = (Rn == sp) ? 31u : (unsigned)Rn->encoding();
+      emit_int32(0x02000000U | (rn_enc << 5) | rd_enc);
+#else
       Assembler::add(Rd, Rn, 0U);
+#endif
+    } else if (Rd == zr || Rn == zr) {
+      // Either Rd is zr (write discarded, no-op) or Rn is zr (writing
+      // integer zero to Rd; the cap-tag-clearing is intended). Use
+      // the classic orr, which knows how to encode HotSpot's pseudo
+      // zr (#32) as the AArch64 ZR (#31) in the ORR instruction
+      // family. Cap-preserving move is not needed here.
+      orr(Rd, zr, Rn);
     } else {
+#ifdef __CHERI_PURE_CAPABILITY__
+      // C-6 fix #8: emit the Morello MOV (Capability) instruction
+      // directly. Encoding: 0xC2C1D000 | (Rn << 5) | Rd, where Rd
+      // and Rn are 5-bit (0..30). Confirmed via Morello clang:
+      //   mov c0, c1  -> 0xC2C1D020
+      //   mov c19, c0 -> 0xC2C1D013
+      //   mov c2, c3  -> 0xC2C1D062
+      // Prior attempts (orr Rd, ZR, Rn — integer; add Rd, Rn, #0 —
+      // also integer ADD imm at opcode 0x91xxxxxx, NOT the cap-ADD
+      // at 0x02xxxxxx) both clear the cap tag. The MOV (Capability)
+      // instruction at 0xC2C1Dxxx is the canonical preserving form.
+      // Concrete symptom: forward_exception's `__ mov(r19, r0)`
+      // had been losing the tag of the exception handler address,
+      // so `__ br(r19)` SIGPROT'd at the tag-zero PC.
+      emit_int32(0xC2C1D000 | (Rn->encoding() << 5) | Rd->encoding());
+#else
