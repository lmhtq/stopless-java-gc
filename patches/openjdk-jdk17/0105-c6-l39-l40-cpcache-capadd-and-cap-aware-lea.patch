--- a/src/hotspot/cpu/aarch64/assembler_aarch64.cpp
+++ b/src/hotspot/cpu/aarch64/assembler_aarch64.cpp
@@ -106,15 +106,47 @@ void Address::lea(MacroAssembler *as, Register r) const {
   case base_plus_offset: {
     if (_offset == 0 && _base == r) // it's a nop
       break;
+#ifdef __CHERI_PURE_CAPABILITY__
+    // C-6 fix #40: lea computes an address from a (capability) base; the
+    // stock integer add/sub strips the base's cap tag so the result
+    // faults when used as a pointer. Use cap-ADD/cap-SUB. Small offsets
+    // (the overwhelmingly common field/header-offset case) use the imm12
+    // form; large offsets materialise into rscratch1 and cap-add by reg.
+    if (_offset >= 0 && _offset < (1 << 12)) {
+      __ cap_add_imm(r, _base, (unsigned)_offset);
+    } else if (_offset < 0 && -_offset < (1 << 12)) {
+      __ cap_sub_imm(r, _base, (unsigned)(-_offset));
+    } else {
+      __ mov(rscratch1, _offset);
+      __ cap_add_reg(r, _base, rscratch1);
+    }
+    break;
+#else
     if (_offset > 0)
       __ add(r, _base, _offset);
     else
       __ sub(r, _base, -_offset);
       break;
+#endif
   }
   case base_plus_offset_reg: {
+#ifdef __CHERI_PURE_CAPABILITY__
+    // cap-add with (optionally shifted) index register, preserving the
+    // base capability. Pre-shift into rscratch1 when a scale is needed.
+    {
+      int sh = MAX2(_ext.shift(), 0);
+      if (sh == 0) {
+        __ cap_add_reg(r, _base, _index);
+      } else {
+        __ lsl(rscratch1, _index, sh);
+        __ cap_add_reg(r, _base, rscratch1);
+      }
+    }
+    break;
+#else
     __ add(r, _base, _index, _ext.op(), MAX2(_ext.shift(), 0));
     break;
+#endif
   }
   case literal: {
     if (rtype == relocInfo::none)
