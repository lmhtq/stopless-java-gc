   // be modified accordingly.
+#ifdef __CHERI_PURE_CAPABILITY__
+  // C-6 fix #39: integer add(cache, rcpool, index, LSL, 5) strips
+  // rcpool's cap tag → later [cache] access faults. Pre-shift the index
+  // into a scratch, then cap-add to keep the ConstantPoolCache capability.
+  lsl(rscratch1, index, 5);
