 void InterpreterMacroAssembler::load_resolved_klass_at_offset(
                              Register cpool, Register index, Register klass, Register temp) {
+#ifdef __CHERI_PURE_CAPABILITY__
+  // C-9: cpool, _resolved_klasses (Array<Klass*>*) and the Klass* are all
+  // capabilities; integer add/ldr strip their tags so the resolved-klass deref
+  // faults (fired in the fast-path `new` of a resolved class). Shift the index
+  // into the operand register (cap_add_reg is uxtx) and cap-LDR each link.
+  // NOTE: in purecap a ConstantPool slot (intptr_t) and an Array<Klass*>
+  // element (Klass* cap) are BOTH 16 bytes, so index by ×16 (exact_log2 of the
+  // 16-byte cap slot), not LogBytesPerWord (×8) — else the final cap-LDR hits
+  // an 8-aligned address and faults SIGBUS (alignment).
+  const int LogCapBytes = exact_log2(wordSize);   // wordSize == 16 in purecap
+  lsl(temp, index, LogCapBytes);
+  cap_add_reg(temp, cpool, temp);                  // temp = &cpool[index]
+  ldrh(temp, Address(temp, sizeof(ConstantPool))); // temp = resolved_klass_index (u2)
+  cap_ldr_imm(klass, cpool, ConstantPool::resolved_klasses_offset_in_bytes());
+  lsl(temp, temp, LogCapBytes);
+  cap_add_reg(klass, klass, temp);                 // klass = &_resolved_klasses[idx]
+  cap_ldr_imm(klass, klass, Array<Klass*>::base_offset_in_bytes());
+#else
   add(temp, cpool, index, LSL, LogBytesPerWord);
   ldrh(temp, Address(temp, sizeof(ConstantPool))); // temp = resolved_klass_index
   ldr(klass, Address(cpool,  ConstantPool::resolved_klasses_offset_in_bytes())); // klass = cpool->_resolved_klasses
   add(klass, klass, temp, LSL, LogBytesPerWord);
   ldr(klass, Address(klass, Array<Klass*>::base_offset_in_bytes()));
+#endif
 }
 
