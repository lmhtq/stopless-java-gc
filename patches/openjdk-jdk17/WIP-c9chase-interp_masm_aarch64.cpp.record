+  get_method(rmethod);
+  // C-6 L57: esp (r20, expression-stack pointer) also returns from the
+  // call detagged — stock HotSpot relies on it being callee-saved, but the
+  // codecache<->libjvm trampoline boundary drops the tag. Its ADDRESS is
+  // intact and lies within the native stack capability (csp), so rebuild a
+  // tagged esp = csp + (esp_addr - csp_addr). Without this, the first
+  // [esp] cap-load/store after a resolve call_VM (e.g. putfield storing an
+  // oop) SIGPROTs. csp's bounds cover the whole stack, which is correct for
+  // an expression-stack pointer.
+  mov(rscratch1, sp);              // rscratch1 = csp address (integer)
+  sub(rscratch2, esp, rscratch1);  // delta = esp_addr - csp_addr
+  // add esp, csp, rscratch2  (cap-add reg: Cd=esp #20, Cn=csp #31, Xm=rscratch2)
+  emit_int32(0xC2A06000U | ((unsigned)rscratch2->encoding() << 16)
+             | (31U << 5) | (unsigned)esp->encoding());
+#endif
 }
 
 void InterpreterMacroAssembler::profile_obj_type(Register obj, const Address& mdo_addr) {
