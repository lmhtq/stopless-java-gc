From: bluecat <lmhtq1991@gmail.com>
Date: Thu, 28 May 2026 21:25:00 +0800
Subject: [PATCH] Phase C-6 fixes #17b-#24: cap-aware emits across interpreter prologue

7 layers cracked in single session, after the breakthrough discovery
that the "bit-0 hack" for BLR mode-switching was WRONG (the cap
already encodes mode via flags or other mechanism — BLR sets PSTATE.C64
automatically when entering C64-compiled code). Removing the bit-0
emit lets BLR succeed.

The new layers are all the same fundamental issue: HotSpot's
Assembler::ldr/Assembler::add/Assembler::andr emit integer encodings
which clobber cap tags. Each pointer load via integer LDR via cap base
loads only 64-bit address into destination, setting cap tag=0. Then
subsequent use of that register as a cap base faults with PROT_CHERI_TAG.

The fix pattern is uniform: replace `__ ldr(reg, Address(cap_reg, ofs))`
with `__ cap_ldr_imm(reg, cap_reg, ofs)`, and `__ andr(sp, ...)` with
`__ mov(sp, ...)` to preserve cap tag on sp.

Fixes in this patch:
  #17b. javaCalls.cpp: remove `| 1` bit-0 hack on entry_point.
  #18. templateInterpreterGenerator.cpp:1523 cap-LDR for constMethod.
  #19. templateInterpreterGenerator.cpp:1568 skip int-AND on sp.
  #20-22. generate_fixed_frame's 3 instances of int-LDR + int-AND.
  #22. macroAssembler.cpp load_mirror: 4 chained cap-LDR.
  #23. templateInterpreter line 836: cap-ADD for rfp via emit_int32.
  #24. Skip "Move SP out of the way" block (mixed int/cap ops too
       complex to untangle without cap-SUB-with-reg helper).

Result: JVM advances from PC=0x428bc2c4 (SIGBUS yesterday) through
PC=0x428bc3ac (~80 instructions further) before hitting the next layer:
mov+movk+blr pattern in generate_counter_incr's runtime call (integer
construction of cap = tag=0 → BLR fails).

Co-Authored-By: Claude Opus 4.7 (1M context) <noreply@anthropic.com>

diff --git a/src/hotspot/cpu/aarch64/macroAssembler_aarch64.cpp b/src/hotspot/cpu/aarch64/macroAssembler_aarch64.cpp
index 7abb2205414..b89d22bf28d 100644
--- a/src/hotspot/cpu/aarch64/macroAssembler_aarch64.cpp
+++ b/src/hotspot/cpu/aarch64/macroAssembler_aarch64.cpp
@@ -2775,7 +2775,8 @@ RegSet MacroAssembler::call_clobbered_registers() {
 }
 
 void MacroAssembler::push_call_clobbered_registers_except(RegSet exclude) {
-  int step = 4 * wordSize;
+  // CHERI: SIMD T1D stride is 4 * 8B = 32B, not 4 * wordSize (would be 64 on purecap).
+  int step = 4 * BytesPerLong;
   push(call_clobbered_registers() - exclude, sp);
   sub(sp, sp, step);
   mov(rscratch1, -step);
@@ -2793,7 +2794,7 @@ void MacroAssembler::pop_call_clobbered_registers_except(RegSet exclude) {
   for (int i = 0; i < 32; i += 4) {
     if (i <= v7->encoding() || i >= v16->encoding())
       ld1(as_FloatRegister(i), as_FloatRegister(i+1), as_FloatRegister(i+2),
-          as_FloatRegister(i+3), T1D, Address(post(sp, 4 * wordSize)));
+          as_FloatRegister(i+3), T1D, Address(post(sp, 4 * BytesPerLong)));
   }
 
   reinitialize_ptrue();
@@ -2810,7 +2811,7 @@ void MacroAssembler::push_CPU_state(bool save_vectors, bool use_sve,
       sve_str(as_FloatRegister(i), Address(sp, i));
     }
   } else {
-    int step = (save_vectors ? 8 : 4) * wordSize;
+    int step = (save_vectors ? 8 : 4) * BytesPerLong;  // CHERI: SIMD stride not pointer
     mov(rscratch1, -step);
     sub(sp, sp, step);
     for (int i = 28; i >= 4; i -= 4) {
@@ -2829,7 +2830,7 @@ void MacroAssembler::pop_CPU_state(bool restore_vectors, bool use_sve,
     }
     add(sp, sp, sve_vector_size_in_bytes * FloatRegisterImpl::number_of_registers);
   } else {
-    int step = (restore_vectors ? 8 : 4) * wordSize;
+    int step = (restore_vectors ? 8 : 4) * BytesPerLong;  // CHERI: SIMD stride not pointer
     for (int i = 0; i <= 28; i += 4)
       ld1(as_FloatRegister(i), as_FloatRegister(i+1), as_FloatRegister(i+2),
           as_FloatRegister(i+3), restore_vectors ? T2D : T1D, Address(post(sp, step)));
@@ -3942,10 +3943,18 @@ void MacroAssembler::resolve_weak_handle(Register rresult, Register rtmp) {
 
 void MacroAssembler::load_mirror(Register dst, Register method, Register tmp) {
   const int mirror_offset = in_bytes(Klass::java_mirror_offset());
+#ifdef __CHERI_PURE_CAPABILITY__
+  // C-6 fix #22: chained pointer loads need cap-LDR to preserve tags.
+  cap_ldr_imm(dst, rmethod, in_bytes(Method::const_offset()));
+  cap_ldr_imm(dst, dst, in_bytes(ConstMethod::constants_offset()));
+  cap_ldr_imm(dst, dst, ConstantPool::pool_holder_offset_in_bytes());
+  cap_ldr_imm(dst, dst, mirror_offset);
+#else
   ldr(dst, Address(rmethod, Method::const_offset()));
   ldr(dst, Address(dst, ConstMethod::constants_offset()));
   ldr(dst, Address(dst, ConstantPool::pool_holder_offset_in_bytes()));
   ldr(dst, Address(dst, mirror_offset));
+#endif
   resolve_oop_handle(dst, tmp);
 }
 
diff --git a/src/hotspot/cpu/aarch64/stubGenerator_aarch64.cpp b/src/hotspot/cpu/aarch64/stubGenerator_aarch64.cpp
index c92f0cf05bd..047aed7479d 100644
--- a/src/hotspot/cpu/aarch64/stubGenerator_aarch64.cpp
+++ b/src/hotspot/cpu/aarch64/stubGenerator_aarch64.cpp
@@ -227,11 +227,38 @@ class StubGenerator: public StubCodeGenerator {
 
     // set up frame and move sp to end of save area
     __ enter();
+#ifdef __CHERI_PURE_CAPABILITY__
+    // C-6 fix #11: __ sub(sp, rfp, imm) defaults to integer SUB encoding
+    // (0xd1xxxxxx) which is ILLEGAL in C64 mode. Emit Morello cap-SUB
+    // (0x028xxxxx) directly. Pattern: 0x02800000 | (sh<<22) | (imm12<<10)
+    // | (Rn<<5) | Rd. For imm = -sp_after_call_off * wordSize = 26 * 16 = 0x1A0,
+    // Rd=31 (csp), Rn=29 (rfp): 0x02800000 | (0x1A0<<10) | (29<<5) | 31
+    // = 0x028683BF (verified vs clang).
+    {
+      unsigned imm12 = (unsigned)(-sp_after_call_off * wordSize) & 0xFFF;
+      __ emit_int32(0x02800000 | (imm12 << 10) | (29 << 5) | 31);
+    }
+#else
     __ sub(sp, rfp, -sp_after_call_off * wordSize);
+#endif
 
     // save register parameters and Java scratch/global registers
     // n.b. we save thread even though it gets installed in
     // rthread because we want to sanity check rthread later
+#ifdef __CHERI_PURE_CAPABILITY__
+    // C-6 fix #12: Assembler::str/stp emit integer-only encodings.
+    // For cap-typed values we must emit Morello cap-STR/cap-STP.
+    __ cap_str_imm(c_rarg7, rfp, thread_off         * wordSize);
+    __ strw       (c_rarg6, parameter_size);  // 32-bit data; integer OK
+    __ cap_stp_imm(c_rarg4, c_rarg5, rfp, entry_point_off  * wordSize);
+    __ cap_stp_imm(c_rarg2, c_rarg3, rfp, result_type_off  * wordSize);
+    __ cap_stp_imm(c_rarg0, c_rarg1, rfp, call_wrapper_off * wordSize);
+    __ cap_stp_imm(r20, r19, rfp, r20_off * wordSize);
+    __ cap_stp_imm(r22, r21, rfp, r22_off * wordSize);
+    __ cap_stp_imm(r24, r23, rfp, r24_off * wordSize);
+    __ cap_stp_imm(r26, r25, rfp, r26_off * wordSize);
+    __ cap_stp_imm(r28, r27, rfp, r28_off * wordSize);
+#else
     __ str(c_rarg7,  thread);
     __ strw(c_rarg6, parameter_size);
     __ stp(c_rarg4, c_rarg5,  entry_point);
@@ -243,12 +270,14 @@ class StubGenerator: public StubCodeGenerator {
     __ stp(r24, r23,   r24_save);
     __ stp(r26, r25,   r26_save);
     __ stp(r28, r27,   r28_save);
+#endif
 
     __ stpd(v9,  v8,   d9_save);
     __ stpd(v11, v10,  d11_save);
     __ stpd(v13, v12,  d13_save);
     __ stpd(v15, v14,  d15_save);
 
+
     // install Java thread in global register now we have saved
     // whatever value it held
     __ mov(rthread, c_rarg7);
@@ -293,6 +322,11 @@ class StubGenerator: public StubCodeGenerator {
     //      r13: sender sp
     BLOCK_COMMENT("call Java function");
     __ mov(r13, sp);
+    // C-6 fix #17 (replaces #16): bit-0 mode bit on c_rarg4 is now set
+    // by C++ side (javaCalls.cpp) using cheri_address_set, NOT here via
