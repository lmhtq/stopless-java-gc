diff --git a/src/hotspot/share/runtime/javaCalls.cpp b/src/hotspot/share/runtime/javaCalls.cpp
index 798cee7a6f8..7378429fca5 100644
--- a/src/hotspot/share/runtime/javaCalls.cpp
+++ b/src/hotspot/share/runtime/javaCalls.cpp
@@ -426,13 +426,50 @@ void JavaCalls::call_helper(JavaValue* result, const methodHandle& method, JavaC
         }
       }
 #endif
+#ifdef __CHERI_PURE_CAPABILITY__
+      // C-6 fix #10: on Morello, BLR to a capability target sets
+      // PSTATE.C64 = target_cap.Value[0]. Our generated stubs are
+      // C64-mode code but the cap returned by StubRoutines::call_stub()
+      // has address 0x...8 (bit 0 = 0), so BLR enters A64 mode and
+      // misinterprets the C64 encoding → CAP_TAG fault on ifetch.
+      // (ARM ARM DDI0606 §2.10 RZTMWK + RZRMXS.) Fix: OR bit 0 into
+      // the cap address before invoking. Uses cheri_address_set to
+      // preserve cap tag/bounds/perms.
+      StubRoutines::CallStub _cs = StubRoutines::call_stub();
+      void* _cs_v = (void*)_cs;
+      unsigned long _cs_addr = (unsigned long)__builtin_cheri_address_get(_cs_v);
+      _cs_v = __builtin_cheri_address_set(_cs_v, _cs_addr | 1);
+      // C-6 fix #17 (new strategy): also flip entry_point bit 0 HERE, via
+      // cheri_address_set rather than via cap-ADD #1 in the stub. The
+      // earlier stub-emit approach (patch 0095) made c4.address odd, but
+      // BLR-cap on Morello (per actual hw behaviour observed via gdb at
