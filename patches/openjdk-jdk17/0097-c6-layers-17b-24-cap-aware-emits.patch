+        bool susp = (top == 0xa9 || top == 0xa8 || top == 0xa7 || top == 0xa6 ||
+                     top == 0xf9 || top == 0xf8 ||
+                     top == 0xd1 || top == 0x91 || top == 0x51 || top == 0xd0 ||
+                     top == 0xaa);
+        if (susp && suspect_count < 20) {
+          fprintf(stderr, "  +%03d: 0x%08x (top=0x%02x)\n", i*4, insn, top);
+          suspect_count++;
+        }
+      }
+      fprintf(stderr, "[C6CSSCAN] total suspect=%d\n", suspect_count);
+      fflush(stderr);
+    }
+#endif
+
     return start;
   }
 
@@ -4910,7 +4991,7 @@ class StubGenerator: public StubCodeGenerator {
     __ cbnz(tmp1, NOT_EQUAL);
     __ ldp(tmp1, tmp3, Address(__ post(a1, 2 * wordSize)));
