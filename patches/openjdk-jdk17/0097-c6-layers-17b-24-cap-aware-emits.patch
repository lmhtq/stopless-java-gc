     // we do this here because the notify will already have been done
@@ -330,7 +364,11 @@ class StubGenerator: public StubCodeGenerator {
     __ BIND(exit);
 
     // pop parameters
+#ifdef __CHERI_PURE_CAPABILITY__
+    __ cap_sub_imm(esp, rfp, (unsigned)(-sp_after_call_off * wordSize));
+#else
     __ sub(esp, rfp, -sp_after_call_off * wordSize);
+#endif
 
 #ifdef ASSERT
     // verify that threads correspond
@@ -354,6 +392,21 @@ class StubGenerator: public StubCodeGenerator {
     __ ldpd(v11, v10,  d11_save);
     __ ldpd(v9,  v8,   d9_save);
 
+#ifdef __CHERI_PURE_CAPABILITY__
+    // C-6 fix #14: cap-LDP for callee-saved register restore (mirror
+    // of cap-STP fix in prologue).
+    __ cap_ldp_imm(r28, r27, rfp, r28_off * wordSize);
