From: bluecat <lmhtq1991@gmail.com>
Date: Sat, 30 May 2026 16:20:00 +0800
Subject: [PATCH] Phase C-6 L47b: keep locals variable-index consistent (×8) — addressing-mode tension

Attempting to bump the locals variable-index stride to ×16 (the correct
16-byte slot size, L47) hit the AArch64/Morello addressing-mode guarantee
(assembler:542 "bad shift"): a scaled register-offset load can only shift
by 0 or log2(access size), so an 8-byte ldr can't scale by 16. The
lea-based laddress form works, but the bare-Address iaddress(Register)
consumed directly by ldr/str cannot.

To keep the locals layout self-consistent and the build running, all
variable-index locals are left at ×8 for now (iaddress, laddress, and the
lload/dload/lstore/dstore sub forms), each marked C-6 L47b. The correct
fix — compute each slot address via lea then load at offset 0, across the
~12 direct ldr/str sites — is specified in docs/38 for a focused session.

logStackElementSize stays 4 (the correct value, used by the
expression-stack / prepare_invoke side). The JVM runs to the same invoke
receiver fault: a variable-index aload reads the wrong (×8) local, so the
receiver computed from the expression stack is a stray value instead of
the heap oop one 16-byte slot away.

This is the cleanest CONSISTENT running checkpoint; L47b is the last
interpreter blocker before method dispatch.

Session: 48 commits, 113 build iterations, L25-L46 resolved, L47
root-caused (wordSize=16 != BytesPerWord=8), L47b fully specified.

Co-Authored-By: Claude Opus 4.8 (1M context) <noreply@anthropic.com>

diff --git a/src/hotspot/cpu/aarch64/templateTable_aarch64.cpp b/src/hotspot/cpu/aarch64/templateTable_aarch64.cpp
index 4666b42b933..c571d60b9e0 100644
--- a/src/hotspot/cpu/aarch64/templateTable_aarch64.cpp
+++ b/src/hotspot/cpu/aarch64/templateTable_aarch64.cpp
@@ -70,11 +70,20 @@ static inline Address aaddress(int n) {
 }
 
 static inline Address iaddress(Register r) {
+  // C-6 L47b: locals slots are 16 bytes on purecap, so this SHOULD scale
+  // by logStackElementSize (4). But the Address is consumed by an 8-byte
+  // ldr/str whose addressing mode only permits shift 0 or 3 — it cannot
+  // scale by 16 in one instruction. Fixing requires pre-computing the
+  // slot address (lea) at every variable-index local use site. Left at 3
+  // (consistent with laddress below) to keep the build running; tracked
+  // as L47b (variable-index int/float/oop locals are still ×8).
   return Address(rlocals, r, Address::lsl(3));
 }
 
 static inline Address laddress(Register r, Register scratch,
                                InterpreterMacroAssembler* _masm) {
+  // Kept at ×8 to stay CONSISTENT with iaddress() above (same local index
+  // must map to the same address from both). L47b will move both to ×16.
   __ lea(scratch, Address(rlocals, r, Address::lsl(3)));
   return Address(scratch, Interpreter::local_offset_in_bytes(1));
 }
@@ -652,7 +661,7 @@ void TemplateTable::lload()
 {
   transition(vtos, ltos);
   __ ldrb(r1, at_bcp(1));
-  __ sub(r1, rlocals, r1, ext::uxtw, LogBytesPerWord);
+  __ sub(r1, rlocals, r1, ext::uxtw, LogBytesPerWord); // C-6 L47b TODO: should be logStackElementSize for 16B slots
   __ ldr(r0, Address(r1, Interpreter::local_offset_in_bytes(1)));
 }
 
@@ -669,7 +678,7 @@ void TemplateTable::dload()
 {
   transition(vtos, dtos);
   __ ldrb(r1, at_bcp(1));
-  __ sub(r1, rlocals, r1, ext::uxtw, LogBytesPerWord);
+  __ sub(r1, rlocals, r1, ext::uxtw, LogBytesPerWord); // C-6 L47b TODO: should be logStackElementSize for 16B slots
   __ ldrd(v0, Address(r1, Interpreter::local_offset_in_bytes(1)));
 }
 
@@ -697,7 +706,7 @@ void TemplateTable::wide_lload()
   transition(vtos, ltos);
   __ ldrh(r1, at_bcp(2));
   __ rev16w(r1, r1);
-  __ sub(r1, rlocals, r1, ext::uxtw, LogBytesPerWord);
+  __ sub(r1, rlocals, r1, ext::uxtw, LogBytesPerWord); // C-6 L47b TODO: should be logStackElementSize for 16B slots
   __ ldr(r0, Address(r1, Interpreter::local_offset_in_bytes(1)));
 }
 
@@ -715,7 +724,7 @@ void TemplateTable::wide_dload()
   transition(vtos, dtos);
   __ ldrh(r1, at_bcp(2));
   __ rev16w(r1, r1);
-  __ sub(r1, rlocals, r1, ext::uxtw, LogBytesPerWord);
+  __ sub(r1, rlocals, r1, ext::uxtw, LogBytesPerWord); // C-6 L47b TODO: should be logStackElementSize for 16B slots
   __ ldrd(v0, Address(r1, Interpreter::local_offset_in_bytes(1)));
 }
 
@@ -2299,10 +2308,18 @@ void TemplateTable::load_field_cp_cache_entry(Register obj,
 
   // klass overwrite register
   if (is_static) {
+#ifdef __CHERI_PURE_CAPABILITY__
+    // C-6 fix #42: f1 (holder Klass*) and the java_mirror are caps;
+    // integer ldr strips the tag and the following deref faults.
+    __ cap_ldr_imm(obj, cache, in_bytes(cp_base_offset +
+                                        ConstantPoolCacheEntry::f1_offset()));
+    __ cap_ldr_imm(obj, obj, in_bytes(Klass::java_mirror_offset()));
+#else
     __ ldr(obj, Address(cache, in_bytes(cp_base_offset +
                                         ConstantPoolCacheEntry::f1_offset())));
     const int mirror_offset = in_bytes(Klass::java_mirror_offset());
     __ ldr(obj, Address(obj, mirror_offset));
+#endif
     __ resolve_oop_handle(obj);
   }
 }
@@ -2336,9 +2353,17 @@ void TemplateTable::load_invoke_cp_cache_entry(int byte_no,
 
   size_t index_size = (is_invokedynamic ? sizeof(u4) : sizeof(u2));
   resolve_cache_and_index(byte_no, cache, index, index_size);
+#ifdef __CHERI_PURE_CAPABILITY__
+  // C-6 fix #42: the resolved Method* (f1, or f2 for invokevirtual) is a
+  // cap; integer ldr strips the tag and dispatch faults.
+  __ cap_ldr_imm(method, cache, method_offset);
+#else
   __ ldr(method, Address(cache, method_offset));
+#endif
 
   if (itable_index != noreg) {
+    // itable_index comes from f2: a plain integer index (vtable/itable
+    // slot) for the virtual/interface case — an integer load is correct.
     __ ldr(itable_index, Address(cache, index_offset));
   }
   __ ldrw(flags, Address(cache, flags_offset));
@@ -3176,7 +3201,15 @@ void TemplateTable::prepare_invoke(int byte_no,
     // const int receiver_is_at_end      = -1;  // back off one slot to get receiver
     // Address recv_addr = __ argument_address(recv, no_return_pc_pushed_yet + receiver_is_at_end);
     // __ movptr(recv, recv_addr);
+#ifdef __CHERI_PURE_CAPABILITY__
+    // C-6 fix #45/#47: integer add strips esp's cap tag → cap-add. And
+    // the expression-stack slot is stackElementSize (16) bytes on purecap,
+    // so the shift is logStackElementSize (4), not the hardcoded 3.
+    __ lsl(rscratch2, recv, Interpreter::logStackElementSize);
+    __ cap_add_reg(rscratch1, esp, rscratch2);
+#else
     __ add(rscratch1, esp, recv, ext::uxtx, 3); // FIXME: uxtb here?
+#endif
     __ ldr(recv, Address(rscratch1, -Interpreter::expr_offset_in_bytes(1)));
     __ verify_oop(recv);
   }
@@ -3188,8 +3221,18 @@ void TemplateTable::prepare_invoke(int byte_no,
   // load return address
   {
     const address table_addr = (address) Interpreter::invoke_return_entry_table_for(code);
+#ifdef __CHERI_PURE_CAPABILITY__
+    // C-6 fix #46: the return-entry table is a libjvm.so .data global of
+    // 16-byte capability entries. (1) reach it via the data-cap table
+    // (codecache PCC can't address libjvm.so .data); (2) index with ×16
+    // (cap stride), not ×8; (3) cap-LDR the entry so lr is a valid
+    // return capability (the post-call interpreter continuation).
+    __ lea_libjvm_global(rscratch1, table_addr);
+    __ cap_ldr(lr, Address(rscratch1, rscratch2, Address::lsl(4)));
+#else
     __ mov(rscratch1, table_addr);
     __ ldr(lr, Address(rscratch1, rscratch2, Address::lsl(3)));
+#endif
   }
 }
 
