From: bluecat <lmhtq1991@gmail.com>
Date: Sat, 30 May 2026 19:00:00 +0800
Subject: [PATCH] Phase C-6 L49: push_ptr/pop_ptr keep oops as capabilities (high-leverage)

After the stack-overlap fix (L48), the invokespecial receiver had the
right heap-oop ADDRESS but tag-0: the object produced by `new` (atos, in
r0) is pushed to the expression stack on the atos→vtos transition via
push_ptr, which used an 8-byte `str` and dropped the cap tag. Every
reference push/pop on the expression stack goes through push_ptr/pop_ptr,
so this is high-leverage.

Fixed both to move the FULL 16-byte oop capability: push_ptr cap-SUBs esp
by one slot then cap-STRs; pop_ptr cap-LDRs then cap-ADDs esp. (push_i/
pop_i etc. stay as-is — ints are not capabilities.)

RESULT: oops keep their tags across the expression stack; execution jumps
~2900 bytes further (the invokespecial <init> now runs). Next fault (L50)
at 0x428c9e40.

Session: 51 commits, 118 build iterations, L25-L49 resolved.

Co-Authored-By: Claude Opus 4.8 (1M context) <noreply@anthropic.com>

diff --git a/src/hotspot/cpu/aarch64/interp_masm_aarch64.cpp b/src/hotspot/cpu/aarch64/interp_masm_aarch64.cpp
index 1db103730f1..0f28d810841 100644
--- a/src/hotspot/cpu/aarch64/interp_masm_aarch64.cpp
+++ b/src/hotspot/cpu/aarch64/interp_masm_aarch64.cpp
@@ -169,9 +169,16 @@ void InterpreterMacroAssembler::get_unsigned_2_byte_index_at_bcp(
 }
 
 void InterpreterMacroAssembler::get_dispatch() {
+#ifdef __CHERI_PURE_CAPABILITY__
+  // C-6 fix #34: PCC-relative adrp to the libjvm.so dispatch table yields
+  // an out-of-range (tag-cleared) cap from the codecache. Load the
+  // pre-seeded dispatch-table capability from the thread instead.
+  cap_ldr_imm(rdispatch, rthread, in_bytes(Thread::cap_dispatch_offset()));
+#else
   uint64_t offset;
   adrp(rdispatch, ExternalAddress((address)Interpreter::dispatch_table()), offset);
   lea(rdispatch, Address(rdispatch, offset));
+#endif
 }
 
 void InterpreterMacroAssembler::get_cache_index_at_bcp(Register index,
@@ -209,13 +216,26 @@ void InterpreterMacroAssembler::get_cache_and_index_at_bcp(Register cache,
   assert_different_registers(cache, index);
   assert_different_registers(cache, rcpool);
   get_cache_index_at_bcp(index, bcp_offset, index_size);
+#ifndef __CHERI_PURE_CAPABILITY__
   assert(sizeof(ConstantPoolCacheEntry) == 4 * wordSize, "adjust code below");
+#endif
   // convert from field index to ConstantPoolCacheEntry
   // aarch64 already has the cache in rcpool so there is no need to
   // install it in cache. instead we pre-add the indexed offset to
   // rcpool and return it in cache. All clients of this method need to
   // be modified accordingly.
+#ifdef __CHERI_PURE_CAPABILITY__
+  // C-6 fix #39/#42: integer add(cache, rcpool, index, LSL, 5) strips
+  // rcpool's cap tag → cap-add instead. AND the entry stride is NOT 32
+  // on CHERI: ConstantPoolCacheEntry is padded to 64 bytes (power-of-2,
+  // because _f1 is a 16-byte cap) so the shift is log2(64)=6, not 5.
+  // Derive it from size_in_bytes() so it tracks the struct.
+  const int cpce_log = exact_log2(in_bytes(ConstantPoolCacheEntry::size_in_bytes()));
+  lsl(rscratch1, index, cpce_log);
+  cap_add_reg(cache, rcpool, rscratch1);
+#else
   add(cache, rcpool, index, Assembler::LSL, 5);
+#endif
 }
 
 
@@ -243,6 +263,17 @@ void InterpreterMacroAssembler::get_cache_entry_pointer_at_bcp(Register cache,
                                                                size_t index_size) {
   assert(cache != tmp, "must use different register");
   get_cache_index_at_bcp(tmp, bcp_offset, index_size);
+#ifdef __CHERI_PURE_CAPABILITY__
+  // C-6 fix #42: the cpcache pointer is a capability and the entry stride
+  // is the (padded) 64-byte size (shift = log2(size)), not 32. Use
+  // cap-LDR to read rcpool from the frame, then cap-ADD the header and
+  // the index*stride so the resulting entry pointer keeps its cap tag.
+  const int cpce_log = exact_log2(in_bytes(ConstantPoolCacheEntry::size_in_bytes()));
+  cap_ldr_imm(cache, rfp, frame::interpreter_frame_cache_offset * wordSize);
+  cap_add_imm(cache, cache, in_bytes(ConstantPoolCache::base_offset()));
+  lsl(tmp, tmp, cpce_log);
+  cap_add_reg(cache, cache, tmp);
+#else
   assert(sizeof(ConstantPoolCacheEntry) == 4 * wordSize, "adjust code below");
   // convert from field index to ConstantPoolCacheEntry index
   // and from word offset to byte offset
@@ -251,16 +282,27 @@ void InterpreterMacroAssembler::get_cache_entry_pointer_at_bcp(Register cache,
   // skip past the header
   add(cache, cache, in_bytes(ConstantPoolCache::base_offset()));
   add(cache, cache, tmp, Assembler::LSL, 2 + LogBytesPerWord);  // construct pointer to cache entry
+#endif
 }
 
 void InterpreterMacroAssembler::get_method_counters(Register method,
                                                     Register mcs, Label& skip) {
   Label has_counters;
+#ifdef __CHERI_PURE_CAPABILITY__
+  // C-6 fix #30: MethodCounters* is a cap; integer ldr strips the tag
+  // and the subsequent counter increment via mcs base faults.
+  cap_ldr_imm(mcs, method, in_bytes(Method::method_counters_offset()));
+  cbnz(mcs, has_counters);
+  call_VM(noreg, CAST_FROM_FN_PTR(address,
+          InterpreterRuntime::build_method_counters), method);
+  cap_ldr_imm(mcs, method, in_bytes(Method::method_counters_offset()));
+#else
   ldr(mcs, Address(method, Method::method_counters_offset()));
   cbnz(mcs, has_counters);
   call_VM(noreg, CAST_FROM_FN_PTR(address,
           InterpreterRuntime::build_method_counters), method);
   ldr(mcs, Address(method, Method::method_counters_offset()));
+#endif
   cbz(mcs, skip); // No MethodCounters allocated, OutOfMemory
   bind(has_counters);
 }
@@ -329,7 +371,15 @@ void InterpreterMacroAssembler::gen_subtype_check(Register Rsub_klass,
 // Java Expression Stack
 
 void InterpreterMacroAssembler::pop_ptr(Register r) {
+#ifdef __CHERI_PURE_CAPABILITY__
+  // C-6 fix #49: a reference/oop on the expression stack is a 16-byte
+  // capability; an 8-byte ldr drops its tag. cap-LDR the full slot, then
+  // bump esp by one (16-byte) slot. High-leverage: every atos/oop pop.
+  cap_ldr_imm(r, esp, 0);
+  cap_add_imm(esp, esp, (unsigned)wordSize);
+#else
   ldr(r, post(esp, wordSize));
+#endif
 }
 
 void InterpreterMacroAssembler::pop_i(Register r) {
@@ -341,7 +391,14 @@ void InterpreterMacroAssembler::pop_l(Register r) {
 }
 
 void InterpreterMacroAssembler::push_ptr(Register r) {
+#ifdef __CHERI_PURE_CAPABILITY__
+  // C-6 fix #49: push the full 16-byte oop capability (decrement esp by
+  // one slot, cap-STR) so the reference keeps its tag on the stack.
+  cap_sub_imm(esp, esp, (unsigned)wordSize);
+  cap_str_imm(r, esp, 0);
+#else
   str(r, pre(esp, -wordSize));
+#endif
  }
 
 void InterpreterMacroAssembler::push_i(Register r) {
@@ -478,6 +535,37 @@ void InterpreterMacroAssembler::dispatch_base(TosState state,
     tbnz(rscratch2, exact_log2(SafepointMechanism::poll_bit()), safepoint);
   }
 
+#ifdef __CHERI_PURE_CAPABILITY__
+  // C-6 fix #37: the dispatch table holds `address` entries which are
+  // 16-byte capabilities in purecap, but the stock indexing uses uxtw(3)
+  // (×8), so odd bytecodes read the metadata half of an entry (a value
+  // like 0xfc5fc000...) instead of the handler PC and br lands in
+  // garbage. We need ×16 indexing — but the hardware register-offset
+  // addressing mode only allows a shift of 0 or log2(access size)=3 for
+  // an 8-byte ldr (assembler_aarch64.hpp:539 guarantee). So pre-scale
+  // the (element) index by 16 with an explicit lsl and use shift 0. The
+  // 8-byte ldr then reads the entry's address half = the handler PC, and
+  // br (integer) reaches it within the codecache PCC.
+  // distance_from_dispatch_table already returns an ELEMENT count.
+  if (table == Interpreter::dispatch_table(state)) {
+    addw(rscratch2, rscratch1, Interpreter::distance_from_dispatch_table(state));
+    lslw(rscratch2, rscratch2, 4);
+    ldr(rscratch2, Address(rdispatch, rscratch2, Address::uxtw(0)));
+  } else {
+    mov(rscratch2, (address)table);
+    lslw(rscratch1, rscratch1, 4);
+    ldr(rscratch2, Address(rscratch2, rscratch1, Address::uxtw(0)));
+  }
+  br(rscratch2);
+
+  if (needs_thread_local_poll) {
+    bind(safepoint);
+    lea(rscratch2, ExternalAddress((address)safepoint_table));
+    lslw(rscratch1, rscratch1, 4);
+    ldr(rscratch2, Address(rscratch2, rscratch1, Address::uxtw(0)));
+    br(rscratch2);
+  }
+#else
   if (table == Interpreter::dispatch_table(state)) {
     addw(rscratch2, rscratch1, Interpreter::distance_from_dispatch_table(state));
     ldr(rscratch2, Address(rdispatch, rscratch2, Address::uxtw(3)));
@@ -493,6 +581,7 @@ void InterpreterMacroAssembler::dispatch_base(TosState state,
     ldr(rscratch2, Address(rscratch2, rscratch1, Address::uxtw(3)));
     br(rscratch2);
   }
+#endif
 }
 
 void InterpreterMacroAssembler::dispatch_only(TosState state, bool generate_poll) {
@@ -1635,6 +1724,16 @@ void InterpreterMacroAssembler::call_VM_base(Register oop_result,
 // interpreter specific
   restore_bcp();
   restore_locals();
+#ifdef __CHERI_PURE_CAPABILITY__
+  // C-6 fix #28: rmethod = r12 is a caller-saved temporary, so it is
+  // clobbered across the call_VM (the C runtime / trampoline leaves a
+  // tag-0 integer in it). Stock AArch64 leaves the integer value intact
+  // by luck and callers that use `method` after call_VM see the right
+  // address — but on CHERI a tag-0 base faults PROT_CHERI_TAG on first
+  // use. Reload rmethod with a tagged cap from the frame, mirroring the
+  // bcp/locals restores above.
+  get_method(rmethod);
+#endif
 }
 
 void InterpreterMacroAssembler::profile_obj_type(Register obj, const Address& mdo_addr) {
