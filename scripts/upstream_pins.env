# Pinned upstream commits / tags.
# Source of truth for reproducibility. Updated only by deliberate intent.
# When bumping a pin, rebase any affected patches in the same commit.

# CTSRD-CHERI cheribuild — the toolchain orchestrator
CHERIBUILD_REPO="https://github.com/CTSRD-CHERI/cheribuild.git"
CHERIBUILD_REF="main"            # TODO(phase0-spike): pin to specific SHA

# OpenJDK 17u — base JDK we patch
OPENJDK_REPO="https://github.com/openjdk/jdk17u.git"
OPENJDK_REF="jdk-17.0.13-ga"     # tagged release; locks ABI surface

# MOJO — Manchester / THG port of OpenJDK 17 to CheriBSD/Morello
# NOTE: at the time of writing the MOJO patch series is distributed as
# tarballs from www.mojo-jvm.org rather than a public git repo. The
# bootstrap script handles both forms; update this URL when MOJO opens
# a public repo.
MOJO_PATCHES_URL="https://www.mojo-jvm.org/dist/openjdk17-cheribsd-patches-latest.tar.gz"
MOJO_PATCHES_SHA256=""           # fill in once first downloaded

# CheriBSD — OS image and Cornucopia revoke userland
CHERIBSD_REPO="https://github.com/CTSRD-CHERI/cheribsd.git"
CHERIBSD_REF="main"              # TODO(phase0-spike): pin to release tag (e.g. cheribsd-25.03)

# CTSRD-CHERI/qemu — CHERI-aware QEMU
CHERI_QEMU_REPO="https://github.com/CTSRD-CHERI/qemu.git"
CHERI_QEMU_REF="qemu-cheri"

# DaCapo benchmark suite — the standard JVM workload set
DACAPO_URL="https://downloads.sourceforge.net/project/dacapobench/23.11-MR1-chopin/dacapo-23.11-MR1-chopin.zip"
DACAPO_SHA256=""                 # fill in once first downloaded

# Renaissance — modern JVM benchmark suite (companion to DaCapo)
RENAISSANCE_URL="https://github.com/renaissance-benchmarks/renaissance/releases/download/v0.15.0/renaissance-gpl-0.15.0.jar"
RENAISSANCE_SHA256=""

# Morello FVP — Arm's free Fixed Virtual Platform. Manual download is required
# (EULA). The bootstrap script verifies presence at the path below.
MORELLO_FVP_PATH="third_party/morello-fvp/FVP_Morello"
